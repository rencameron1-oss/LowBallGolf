---
import siteConfig from '../../config/site';

interface Props {
  heading?: string;
  email?: string;
  email_subject?: string;
  location?: string;
  location_detail?: string;
  response_time?: string;
  cta_text?: string;
}

const {
  heading = 'Start a Conversation',
  email = siteConfig.social.email,
  email_subject = siteConfig.booking.emailSubject,
  location = 'Melbourne, Victoria',
  location_detail = 'Available Australia-wide',
  response_time = 'Usually within a couple of business days',
  cta_text = 'Send Email',
} = Astro.props;

const mailtoUrl = email ? `mailto:${email}?subject=${encodeURIComponent(email_subject)}` : '';
---

{email && (
  <section class="py-16 md:py-24">
    <div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="reveal">
        <div class="bg-brand-surface border border-brand-border/30 rounded-2xl p-8">
          {heading && (
            <h2 class="text-2xl font-heading font-bold text-brand-text mb-6">{heading}</h2>
          )}
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-brand-accent/10 flex items-center justify-center flex-shrink-0 mt-1">
                <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-brand-text mb-1">Email</h3>
                <a
                  href={mailtoUrl}
                  class="text-brand-accent hover:text-brand-accent-light transition-colors"
                >
                  {email}
                </a>
              </div>
            </div>
            {location && (
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-full bg-brand-accent/10 flex items-center justify-center flex-shrink-0 mt-1">
                  <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-brand-text mb-1">Based in</h3>
                  <p class="text-brand-muted">{location}</p>
                  {location_detail && (
                    <p class="text-brand-muted text-sm">{location_detail}</p>
                  )}
                </div>
              </div>
            )}
            {response_time && (
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-full bg-brand-accent/10 flex items-center justify-center flex-shrink-0 mt-1">
                  <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-brand-text mb-1">Response Time</h3>
                  <p class="text-brand-muted">{response_time}</p>
                </div>
              </div>
            )}
          </div>
          {cta_text && mailtoUrl && (
            <div class="mt-8">
              <a
                href={mailtoUrl}
                class="inline-flex items-center justify-center w-full gap-2 px-8 py-4 text-lg font-semibold rounded-lg bg-brand-accent text-white hover:bg-brand-accent-light transition-colors"
              >
                {cta_text}
              </a>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
)}
