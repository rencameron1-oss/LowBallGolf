---
import Container from '@bands/ui/components/ui/Container.astro';
import SectionHeading from '@bands/ui/components/ui/SectionHeading.astro';
import Button from '../ui/Button.astro';
import { getCollection } from 'astro:content';

interface Props {
  kicker?: string;
  heading?: string;
  subheading?: string;
  columns?: number | string;
  limit?: number | string;
  cta_text?: string;
  cta_url?: string;
}

const {
  kicker,
  heading,
  subheading,
  columns = 3,
  limit,
  cta_text,
  cta_url,
} = Astro.props;

const allStudies = (await getCollection('caseStudies')).sort(
  (a, b) => (a.data.order ?? 0) - (b.data.order ?? 0),
);
const normalizedLimit = Number(limit);
const studies = normalizedLimit > 0 ? allStudies.slice(0, normalizedLimit) : allStudies;

const normalizedColumns = Number(columns) || 3;
const colClasses: Record<number, string> = {
  2: 'grid-cols-1 md:grid-cols-2',
  3: 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3',
  4: 'grid-cols-1 md:grid-cols-2 xl:grid-cols-4',
};
---

{studies.length > 0 && (
  <section class="py-16 md:py-24">
    <Container width="wide">
      {(heading || subheading || kicker) && (
        <div class="reveal">
          <SectionHeading kicker={kicker} heading={heading || ''} subheading={subheading} />
        </div>
      )}

      <div class:list={['grid gap-6', colClasses[normalizedColumns] || colClasses[3]]}>
        {studies.map((study, index) => (
          <article class={`reveal reveal-delay-${Math.min((index % 3) + 1, 3)} rounded-[1.75rem] border border-brand-border/70 bg-brand-surface overflow-hidden paper-shadow`}>
            {study.data.hero_image && (
              <div class="aspect-[16/10] overflow-hidden">
                <img
                  src={study.data.hero_image}
                  alt={study.data.title}
                  class="h-full w-full object-cover"
                  loading="lazy"
                />
              </div>
            )}
            <div class="p-7">
              <p class="text-xs uppercase tracking-[0.2em] text-brand-accent">{study.data.client} · {study.data.year}</p>
              <h3 class="mt-3 text-2xl font-heading font-semibold text-brand-text">{study.data.title}</h3>
              <p class="mt-3 text-brand-muted leading-relaxed">{study.data.summary}</p>
              <div class="mt-5 flex flex-wrap gap-2">
                {study.data.services.map((service) => (
                  <span class="rounded-full border border-brand-border bg-brand-primary px-3 py-1 text-[11px] uppercase tracking-[0.16em] text-brand-muted">
                    {service}
                  </span>
                ))}
              </div>
              <div class="mt-6">
                <Button href={`/work/${study.id}`} variant="outline">Read case study</Button>
              </div>
            </div>
          </article>
        ))}
      </div>

      {cta_text && cta_url && (
        <div class="mt-12 flex justify-center reveal">
          <Button href={cta_url} variant="primary">{cta_text}</Button>
        </div>
      )}
    </Container>
  </section>
)}
