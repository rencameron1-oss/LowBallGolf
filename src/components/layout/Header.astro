---
import siteConfig from '../../config/site';
import fs from 'node:fs';
import Button from '../ui/Button.astro';
import BrandMark from './BrandMark.astro';

interface Props {
  theme?: 'light' | 'dark';
  /** Transparent over the page hero; solid bar appears after scrolling past it. */
  overlay?: boolean;
}

const { theme = 'light', overlay = false } = Astro.props;
const isDark = theme === 'dark';

// Read navigation from CMS-managed JSON, fall back to static config
let mainNav: { label: string; href: string; children?: { label: string; href: string }[] }[] = [];
try {
  const navData = JSON.parse(fs.readFileSync('src/content/navigation/main.json', 'utf-8'));
  mainNav = navData.items || [];
} catch {
  const { mainNav: staticNav } = await import('../../config/navigation');
  mainNav = staticNav;
}

// The slide-out drawer: browse destinations first, then the site pages.
const drawerBrowse = [
  { label: 'Clubs', href: '/drivers' },
  { label: 'Biggest Price Drop', href: '/drivers' },
  { label: 'Merch', soon: true },
  { label: 'Reviews', soon: true },
];
---

<header
  id="site-header"
  data-theme={theme}
  data-overlay={overlay ? 'true' : undefined}
  class:list={[
    'site-header-shell fixed top-0 left-0 right-0 z-50 transition-all duration-500 header-transparent',
    overlay && 'header-overlay',
  ]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-18 md:h-20">
      <!-- Brand: opens the browse drawer -->
      <button
        id="drawer-btn"
        class="flex items-center gap-2 group cursor-pointer"
        aria-controls="side-drawer"
        aria-expanded="false"
        aria-label="Open menu"
      >
        <BrandMark
          theme={theme}
          size="header"
          class:list={[
            'transition-transform duration-300 group-hover:translate-y-[-1px]',
            isDark ? 'text-white' : 'text-brand-text',
          ]}
        />
        <svg
          class:list={['w-4 h-4 opacity-60 transition-transform duration-300 group-hover:translate-y-[1px]', isDark ? 'text-white' : 'text-brand-text']}
          fill="none" stroke="currentColor" stroke-width="2.4" viewBox="0 0 24 24" aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </button>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-6 xl:gap-8" aria-label="Main navigation">
        {mainNav.map((item) => (
          <div class="relative group flex items-center">
            <a
              href={item.href}
              class:list={[
                'flex items-center gap-1 text-[13px] font-medium transition-colors duration-300 tracking-[0.16em] uppercase leading-none whitespace-nowrap',
                isDark ? 'text-white/72 hover:text-white' : 'text-brand-muted hover:text-brand-text',
              ]}
            >
              {item.label}
              {item.children && (
                <svg class="w-3 h-3 opacity-50 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              )}
            </a>
            {item.children && (
              <div class="absolute top-full left-1/2 -translate-x-1/2 pt-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform group-hover:translate-y-0 translate-y-2">
                <div
                  class:list={[
                    'rounded-xl py-3 min-w-[220px]',
                    isDark
                      ? 'header-dropdown-dark'
                      : 'glass border border-brand-border/80 paper-shadow',
                  ]}
                >
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class:list={[
                        'block px-5 py-2.5 text-sm transition-all duration-200',
                        isDark ? 'text-white/72 hover:text-white hover:bg-white/6' : 'text-brand-muted hover:text-brand-text hover:bg-brand-accent/10',
                      ]}
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
        <Button href={siteConfig.booking.ctaUrl} size="sm" class={isDark ? 'header-cta-dark' : ''}>
          {siteConfig.booking.ctaText}
        </Button>
      </nav>

      <!-- Mobile: hamburger opens the same drawer -->
      <button
        id="drawer-btn-mobile"
        class:list={[
          'lg:hidden relative z-50 flex min-h-11 min-w-11 items-center justify-center rounded-full p-2',
          isDark ? 'text-white' : 'text-brand-text',
        ]}
        aria-controls="side-drawer"
        aria-expanded="false"
        aria-label="Open menu"
      >
        <div class="w-6 h-5 relative flex flex-col justify-between">
          <span class="block h-0.5 w-6 bg-current"></span>
          <span class="block h-0.5 w-6 bg-current"></span>
          <span class="block h-0.5 w-4 bg-current ml-auto"></span>
        </div>
      </button>
    </div>
  </div>
</header>

<!-- Off-canvas drawer -->
<div id="drawer-backdrop" class="drawer-backdrop" hidden></div>
<aside id="side-drawer" class="side-drawer" aria-label="Browse LowballGolf" aria-hidden="true">
  <div class="side-drawer__head">
    <span class="side-drawer__brand">LOWBALL<span>G</span>OLF</span>
    <button id="drawer-close" class="side-drawer__close" aria-label="Close menu">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
        <path d="M6 6l12 12M18 6L6 18" />
      </svg>
    </button>
  </div>

  <nav class="side-drawer__section" aria-label="Browse">
    <p class="side-drawer__label">Browse</p>
    {drawerBrowse.map((item) =>
      item.soon ? (
        <span class="side-drawer__link side-drawer__link--soon">
          {item.label} <em>SOON</em>
        </span>
      ) : (
        <a class="side-drawer__link" href={item.href}>{item.label}</a>
      )
    )}
  </nav>

  <nav class="side-drawer__section" aria-label="Pages">
    <p class="side-drawer__label">Site</p>
    <a class="side-drawer__link side-drawer__link--small" href="/">Home</a>
    {mainNav
      .filter((i) => i.href !== '/')
      .map((item) => (
        <a class="side-drawer__link side-drawer__link--small" href={item.href}>{item.label}</a>
      ))}
  </nav>
</aside>

<!-- Spacer to account for fixed header (cancelled by overlay heroes) -->
<div class="site-header-spacer"></div>

<style>
  .site-header-shell {
    padding-top: max(env(safe-area-inset-top), 0.7rem);
  }

  .site-header-spacer {
    height: calc(4.5rem + max(env(safe-area-inset-top), 0.7rem));
  }

  .header-transparent {
    background: rgba(246, 241, 232, 0.76);
  }

  .header-transparent[data-theme='dark'] {
    background: rgba(var(--color-brand-dark-surface-rgb), 0.64);
    backdrop-filter: blur(18px) saturate(140%);
    -webkit-backdrop-filter: blur(18px) saturate(140%);
    border-bottom: 1px solid var(--color-brand-dark-border);
  }

  .header-scrolled {
    background: rgba(255, 253, 249, 0.9);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid rgba(214, 202, 185, 0.95);
  }

  .header-scrolled[data-theme='dark'] {
    background: rgba(var(--color-brand-dark-surface-rgb), 0.88);
    backdrop-filter: blur(20px) saturate(160%);
    -webkit-backdrop-filter: blur(20px) saturate(160%);
    border-bottom: 1px solid var(--color-brand-dark-border);
  }

  /* Overlay mode: nothing but the wordmark floats on the hero until the
     visitor scrolls past it, then the solid bar fades in. */
  .header-overlay:not(.header-scrolled) {
    background: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border-bottom: 0;
  }

  .header-overlay:not(.header-scrolled) :is(a, button, span, svg, nav a) {
    color: #f2f4ef;
  }

  .header-overlay:not(.header-scrolled) nav a:hover {
    color: #f5c944;
  }

  .header-dropdown-dark {
    border: 1px solid var(--color-brand-dark-border);
    background: rgba(var(--color-brand-dark-surface-rgb), 0.96);
    box-shadow: 0 20px 45px rgba(0, 0, 0, 0.34);
  }

  .header-cta-dark {
    background: var(--color-brand-dark-accent);
    color: white;
  }

  .header-cta-dark:hover {
    background: var(--color-brand-dark-accent-light);
  }

  @media (min-width: 768px) {
    .site-header-shell {
      padding-top: max(env(safe-area-inset-top), 0rem);
    }

    .site-header-spacer {
      height: calc(5rem + max(env(safe-area-inset-top), 0rem));
    }
  }

  /* ---------- off-canvas drawer ---------- */
  .drawer-backdrop {
    position: fixed;
    inset: 0;
    z-index: 60;
    background: rgba(5, 20, 13, 0.55);
    backdrop-filter: blur(3px);
    -webkit-backdrop-filter: blur(3px);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .drawer-backdrop.open {
    opacity: 1;
  }

  .side-drawer {
    position: fixed;
    top: 0;
    bottom: 0;
    left: 0;
    z-index: 70;
    width: min(320px, 86vw);
    padding: 26px 30px 40px;
    box-sizing: border-box;
    overflow-y: auto;
    background: #092619;
    color: #f2f4ef;
    transform: translateX(-102%);
    transition: transform 0.35s cubic-bezier(0.32, 0.72, 0.35, 1);
    box-shadow: 24px 0 60px rgba(0, 0, 0, 0.35);
  }

  .side-drawer.open {
    transform: translateX(0);
  }

  .side-drawer__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 30px;
  }

  .side-drawer__brand {
    font-family: 'Archivo', sans-serif;
    font-weight: 900;
    font-stretch: 72%;
    font-size: 22px;
    letter-spacing: 0.01em;
    color: #f5c944;
  }

  .side-drawer__brand span {
    color: #f2f4ef;
  }

  .side-drawer__close {
    width: 38px;
    height: 38px;
    display: grid;
    place-items: center;
    background: none;
    border: 1px solid rgba(201, 212, 201, 0.3);
    border-radius: 6px;
    color: #c9d4c9;
    cursor: pointer;
  }

  .side-drawer__close:hover {
    color: #f5c944;
    border-color: #f5c944;
  }

  .side-drawer__close svg {
    width: 16px;
    height: 16px;
  }

  .side-drawer__section {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-bottom: 26px;
  }

  .side-drawer__label {
    margin: 0 0 10px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(201, 212, 201, 0.55);
  }

  .side-drawer__link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 0;
    font-family: 'Archivo', sans-serif;
    font-weight: 800;
    font-stretch: 80%;
    font-size: 21px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #f2f4ef;
    text-decoration: none;
    border-bottom: 1px dashed rgba(201, 212, 201, 0.18);
    transition: color 0.15s ease, padding-left 0.15s ease;
  }

  a.side-drawer__link:hover {
    color: #f5c944;
    padding-left: 6px;
  }

  .side-drawer__link--small {
    font-size: 15px;
    font-weight: 600;
    padding: 8px 0;
  }

  .side-drawer__link--soon {
    opacity: 0.45;
    cursor: default;
  }

  .side-drawer__link--soon em {
    font-style: normal;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.14em;
    padding: 2px 5px;
    border: 1px solid currentColor;
    border-radius: 3px;
  }
</style>

<script>
  // Scroll-based header background. Overlay pages wait until the visitor
  // has scrolled past (most of) the hero before showing the solid bar.
  const header = document.getElementById('site-header');
  const isOverlay = header?.dataset.overlay === 'true';
  const threshold = () => (isOverlay ? Math.max(window.innerHeight - 120, 200) : 60);
  const handleScroll = () => {
    if (window.scrollY > threshold()) {
      header?.classList.remove('header-transparent');
      header?.classList.add('header-scrolled');
    } else {
      header?.classList.remove('header-scrolled');
      header?.classList.add('header-transparent');
    }
  };
  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll();

  // Off-canvas drawer
  const drawer = document.getElementById('side-drawer');
  const backdrop = document.getElementById('drawer-backdrop');
  const triggers = [
    document.getElementById('drawer-btn'),
    document.getElementById('drawer-btn-mobile'),
  ].filter(Boolean) as HTMLElement[];

  const setOpen = (open: boolean) => {
    drawer?.classList.toggle('open', open);
    drawer?.setAttribute('aria-hidden', String(!open));
    triggers.forEach((t) => t.setAttribute('aria-expanded', String(open)));
    if (backdrop) {
      if (open) {
        backdrop.hidden = false;
        requestAnimationFrame(() => backdrop.classList.add('open'));
      } else {
        backdrop.classList.remove('open');
        setTimeout(() => (backdrop.hidden = true), 300);
      }
    }
    document.body.style.overflow = open ? 'hidden' : '';
  };

  triggers.forEach((t) =>
    t.addEventListener('click', () => setOpen(!drawer?.classList.contains('open')))
  );
  document.getElementById('drawer-close')?.addEventListener('click', () => setOpen(false));
  backdrop?.addEventListener('click', () => setOpen(false));
  document.addEventListener('keydown', (ev) => {
    if (ev.key === 'Escape') setOpen(false);
  });
  drawer?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
</script>
