---
interface Props {
  body?: any;
  max_width?: 'narrow' | 'default' | 'wide';
  alignment?: 'left' | 'center';
}

const {
  body,
  max_width = 'narrow',
  alignment = 'left',
} = Astro.props;

const widthClasses: Record<string, string> = {
  narrow: 'max-w-3xl',
  default: 'max-w-5xl',
  wide: 'max-w-7xl',
};

/**
 * TinaCMS rich-text stored in markdown frontmatter is typically a
 * structured object. When read from plain markdown YAML it becomes
 * a simple string. We handle both cases.
 */
function renderBody(body: any): string {
  if (!body) return '';
  if (typeof body === 'string') return body;

  // TinaCMS rich-text AST — walk children and extract text
  if (body.children) {
    return body.children
      .map((node: any) => {
        if (node.type === 'p') {
          const text = extractText(node);
          return `<p>${text}</p>`;
        }
        if (node.type === 'h2') return `<h2>${extractText(node)}</h2>`;
        if (node.type === 'h3') return `<h3>${extractText(node)}</h3>`;
        if (node.type === 'ul') {
          const items = (node.children || [])
            .map((li: any) => `<li>${extractText(li)}</li>`)
            .join('');
          return `<ul>${items}</ul>`;
        }
        if (node.type === 'ol') {
          const items = (node.children || [])
            .map((li: any) => `<li>${extractText(li)}</li>`)
            .join('');
          return `<ol>${items}</ol>`;
        }
        if (node.type === 'blockquote') return `<blockquote>${extractText(node)}</blockquote>`;
        return extractText(node);
      })
      .join('\n');
  }

  return String(body);
}

function extractText(node: any): string {
  if (!node) return '';
  if (typeof node === 'string') return node;
  if (node.text !== undefined) {
    let text = node.text;
    if (node.bold) text = `<strong>${text}</strong>`;
    if (node.italic) text = `<em>${text}</em>`;
    return text;
  }
  if (node.children) {
    return node.children.map(extractText).join('');
  }
  return '';
}

const html = renderBody(body);
---

<section class="py-20 md:py-28">
  <div class:list={[
    'mx-auto px-4 sm:px-6 lg:px-8 reveal',
    widthClasses[max_width] || widthClasses.narrow,
    alignment === 'center' ? 'text-center' : 'text-left',
  ]}>
    <div
      class="prose prose-invert prose-lg max-w-none prose-headings:font-heading prose-headings:text-brand-champagne prose-p:text-brand-champagne/70 prose-a:text-brand-accent prose-strong:text-brand-champagne prose-blockquote:border-brand-accent/40 prose-li:text-brand-champagne/70"
      set:html={html}
    />
  </div>
</section>
