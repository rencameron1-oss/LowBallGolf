# TinaCMS
TINA_CLIENT_ID=
TINA_TOKEN=
TINA_PUBLIC_IS_LOCAL=true

# Site URL used by Astro while building canonical URLs and sitemap output.
PUBLIC_SITE_URL=https://example.com

# Analytics (GA4 Measurement ID, e.g. G-XXXXXXXXXX)
PUBLIC_GA_ID=

# Supabase — price data pipeline (npm run ingest) and price pages.
# URL and anon key are safe to expose publicly; the SERVICE key bypasses
# row security — keep it out of the repo and out of the website.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
