---
import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';

interface ArticleItem {
  url?: string;
  image?: string;
  meta?: string;
  title?: string;
  excerpt?: string;
}

interface Props {
  kicker?: string;
  heading?: string;
  subheading?: string;
  items?: ArticleItem[];
  columns?: number | string;
}

const {
  kicker,
  heading,
  subheading,
  items = [],
  columns = 3,
} = Astro.props;

const normalizedColumns = Number(columns) || 3;
const colClasses: Record<number, string> = {
  2: 'grid-cols-1 md:grid-cols-2',
  3: 'grid-cols-1 md:grid-cols-2 xl:grid-cols-3',
  4: 'grid-cols-1 md:grid-cols-2 xl:grid-cols-4',
};
---

{items.length > 0 && (
  <section class="py-20 md:py-28">
    <Container width="wide">
      {(heading || subheading || kicker) && (
        <div class="reveal">
          <SectionHeading kicker={kicker} heading={heading || ''} subheading={subheading} />
        </div>
      )}

      <div class:list={['grid gap-6 md:gap-8', colClasses[normalizedColumns] || colClasses[3]]}>
        {items.map((item, index) => {
          const cardClasses =
            'group overflow-hidden rounded-[1.8rem] border border-brand-border/40 bg-white shadow-[0_20px_55px_rgba(15,23,42,0.06)] transition-all duration-300 hover:-translate-y-1 hover:border-brand-accent/30 hover:shadow-[0_24px_64px_rgba(15,23,42,0.12)]';

          const cardBody = (
            <>
              {item.image && (
                <div class="aspect-[4/3] overflow-hidden bg-brand-surface-alt">
                  <img
                    src={item.image}
                    alt={item.title || 'Article image'}
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="flex h-full flex-col gap-4 p-6">
                {item.meta && (
                  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-accent/80">
                    {item.meta}
                  </p>
                )}
                {item.title && (
                  <h3 class="text-2xl font-heading font-semibold tracking-tight text-brand-text">
                    {item.title}
                  </h3>
                )}
                {item.excerpt && (
                  <p class="text-base leading-relaxed text-brand-muted">
                    {item.excerpt}
                  </p>
                )}
                {item.url && (
                  <span class="mt-auto inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.16em] text-brand-text">
                    Read more
                    <span aria-hidden="true">+</span>
                  </span>
                )}
              </div>
            </>
          );

          return item.url ? (
            <a
              href={item.url}
              class:list={[cardClasses, `reveal reveal-delay-${Math.min((index % 4) + 1, 4)}`]}
            >
              {cardBody}
            </a>
          ) : (
            <article class:list={[cardClasses, `reveal reveal-delay-${Math.min((index % 4) + 1, 4)}`]}>
              {cardBody}
            </article>
          );
        })}
      </div>
    </Container>
  </section>
)}
