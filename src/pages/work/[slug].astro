---
import { getCollection, getEntry, render } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import Container from '@bands/ui/components/ui/Container.astro';
import Button from '../../components/ui/Button.astro';
import StructuredData from '../../components/seo/StructuredData.astro';
import TinaVisualEditing from '../../components/tina/TinaVisualEditing.astro';

export async function getStaticPaths() {
  const caseStudies = await getCollection('caseStudies');
  return caseStudies.map((study) => ({
    params: { slug: study.id },
  }));
}

const { slug } = Astro.params;
const study = slug ? await getEntry('caseStudies', slug) : undefined;

if (!study) {
  throw new Error(`Case study not found: ${slug}`);
}

const { Content } = await render(study);
const caseStudyData = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: study.data.title,
  description: study.data.seo_description || study.data.summary,
  image: study.data.hero_image,
  creator: {
    '@type': 'Organization',
    name: 'Agentic Site Starter',
  },
};
---

<PageLayout
  title={study.data.seo_title || study.data.title}
  description={study.data.seo_description || study.data.summary}
  ogImage={study.data.hero_image}
>
  <TinaVisualEditing collection="caseStudy" relativePath={`${study.id}.md`} />
  <StructuredData data={caseStudyData} />

  <section class="border-b border-brand-border/70 bg-brand-surface/70 py-16 md:py-20">
    <Container width="wide">
      <div class="grid gap-12 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
        <div class="reveal">
          <p class="text-xs uppercase tracking-[0.24em] text-brand-accent">{study.data.client} · {study.data.year}</p>
          <h1 class="mt-4 text-4xl md:text-6xl font-heading font-semibold tracking-tight text-brand-text">
            {study.data.title}
          </h1>
          <p class="mt-5 text-lg text-brand-muted leading-relaxed">
            {study.data.summary}
          </p>
          <p class="mt-6 text-sm uppercase tracking-[0.2em] text-brand-muted">
            Role: {study.data.role}
          </p>
          <div class="mt-8 flex flex-wrap gap-2">
            {study.data.services.map((service) => (
              <span class="rounded-full border border-brand-border bg-brand-primary px-3 py-1 text-[11px] uppercase tracking-[0.16em] text-brand-muted">
                {service}
              </span>
            ))}
          </div>
          {study.data.external_url && (
            <div class="mt-8">
              <Button href={study.data.external_url} target="_blank" rel="noopener noreferrer">
                Visit project
              </Button>
            </div>
          )}
        </div>
        {study.data.hero_image && (
          <div class="reveal reveal-delay-2">
            <div class="overflow-hidden rounded-[1.8rem] border border-brand-border/70 paper-shadow">
              <img
                src={study.data.hero_image}
                alt={study.data.title}
                class="aspect-[16/11] w-full object-cover"
                loading="eager"
              />
            </div>
          </div>
        )}
      </div>
    </Container>
  </section>

  {study.data.stats.length > 0 && (
    <section class="border-b border-brand-border/70 bg-brand-primary-soft">
      <Container width="wide" class="py-8">
        <div class="grid gap-6 md:grid-cols-3">
          {study.data.stats.map((stat) => (
            <div class="rounded-3xl border border-brand-border/70 bg-brand-surface p-6">
              <p class="text-3xl font-heading font-semibold text-brand-text">{stat.value}</p>
              <p class="mt-1 text-xs uppercase tracking-[0.2em] text-brand-muted">{stat.label}</p>
            </div>
          ))}
        </div>
      </Container>
    </section>
  )}

  <section class="py-16 md:py-24">
    <Container width="narrow">
      <div class="prose prose-lg max-w-none">
        <Content />
      </div>
      <div class="mt-12">
        <Button href="/work" variant="outline">Back to work</Button>
      </div>
    </Container>
  </section>
</PageLayout>
