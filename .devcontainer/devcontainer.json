{
  "name": "Agentic Site Starter",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-24-bookworm",
  "forwardPorts": [4330, 4010],
  "portsAttributes": {
    "4330": {
      "label": "Website"
    },
    "4010": {
      "label": "TinaCMS editor"
    }
  },
  "postCreateCommand": "npm install --no-audit --no-fund && npm run doctor",
  "customizations": {
    "vscode": {
      "extensions": [
        "astro-build.astro-vscode",
        "esbenp.prettier-vscode"
      ]
    }
  }
}
