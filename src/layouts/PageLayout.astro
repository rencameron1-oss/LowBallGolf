---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  bodyClass?: string;
  theme?: 'light' | 'dark';
  /** Float the header transparently over the page's own hero; the solid
   *  bar appears once the visitor scrolls past it. */
  overlay?: boolean;
}

const { title, description, ogImage, bodyClass, theme = 'light', overlay = false } = Astro.props;
---

<BaseLayout title={title} description={description} ogImage={ogImage} bodyClass={bodyClass}>
  <Header theme={theme} overlay={overlay} />
  <main>
    <slot />
  </main>
  <Footer theme={theme} />
</BaseLayout>
