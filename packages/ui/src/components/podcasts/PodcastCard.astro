---
interface Props {
  title: string;
  slug: string;
  date: Date;
  series: string;
  guest?: string;
  hero_image?: string;
  duration?: string;
}

const { title, slug, date, series, guest, hero_image, duration } = Astro.props;

const formattedDate = date.toLocaleDateString('en-AU', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});

const seriesLabel = series === 'the-good-girl-confessional'
  ? 'The Good Girl Confessional'
  : 'Alex the Seal Podcast';

const href = `/podcasts/${slug}`;
---

<article class="group flex gap-4">
  {hero_image ? (
    <a href={href} class="flex-shrink-0">
      <div class="w-20 h-20 md:w-24 md:h-24 rounded-full overflow-hidden border-2 border-brand-border">
        <img
          src={hero_image}
          alt={guest || title}
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
        />
      </div>
    </a>
  ) : (
    <a href={href} class="flex-shrink-0">
      <div class="w-20 h-20 md:w-24 md:h-24 rounded-full bg-brand-accent-bg flex items-center justify-center">
        <svg class="w-8 h-8 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z" />
        </svg>
      </div>
    </a>
  )}
  <div class="flex-1 min-w-0">
    <span class="inline-block px-2 py-0.5 text-[10px] font-ui font-semibold uppercase tracking-wider text-brand-accent bg-brand-accent-bg rounded">
      {seriesLabel}
    </span>
    <a href={href}>
      <h3 class="mt-1 text-sm md:text-base font-heading font-bold text-brand-text group-hover:text-brand-accent transition-colors leading-snug line-clamp-2">
        {title}
      </h3>
    </a>
    {guest && (
      <p class="mt-0.5 text-xs text-brand-muted font-ui">with {guest}</p>
    )}
    <div class="mt-1 flex items-center gap-2 text-xs text-brand-muted font-ui">
      <time datetime={date.toISOString()}>{formattedDate}</time>
      {duration && (
        <>
          <span>&middot;</span>
          <span>{duration}</span>
        </>
      )}
    </div>
  </div>
</article>
