---
interface StatItem {
  value?: string;
  label?: string;
}

interface Props {
  stats?: StatItem[];
  background?: 'default' | 'surface';
}

const {
  stats = [],
  background = 'surface',
} = Astro.props;

const bgClasses: Record<string, string> = {
  default: '',
  surface: 'bg-brand-surface',
};
---

{stats.length > 0 && (
  <section class:list={['py-20 md:py-28', bgClasses[background]]}>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class:list={[
        'grid gap-8 md:gap-12',
        stats.length === 2 && 'grid-cols-2',
        stats.length === 3 && 'grid-cols-2 md:grid-cols-3',
        stats.length >= 4 && 'grid-cols-2 md:grid-cols-4',
      ]}>
        {stats.map((stat, i) => (
          <div class={`text-center reveal reveal-delay-${Math.min(i + 1, 4)}`}>
            <div class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold text-gradient">
              {stat.value}
            </div>
            <p class="mt-2 text-brand-muted text-sm md:text-base uppercase tracking-widest">
              {stat.label}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>
)}
