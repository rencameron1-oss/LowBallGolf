---
import PageLayout from '../../layouts/PageLayout.astro';
import Container from '@bands/ui/components/ui/Container.astro';
import PriceChart from '../../components/clubs/PriceChart.astro';
import { fetchClubs, dollars, auDate } from '../../utils/priceData';
import type { ClubData } from '../../utils/priceData';

export async function getStaticPaths() {
  const clubs = await fetchClubs();
  return clubs.map((club) => ({ params: { slug: club.slug }, props: { club } }));
}

interface Props {
  club: ClubData;
}

const { club } = Astro.props;
const best = club.offers[0];
const worst = club.offers[club.offers.length - 1];
const spread = worst.price - best.price;
const daysTracked = club.days.length;
---

<PageLayout
  title={`${club.title} — Compare Prices`}
  description={`${club.title} prices across ${club.offers.length} Australian golf retailers. Best price ${dollars(best.price)} at ${best.name}. Price history and spread tracked nightly.`}
  ogImage={club.image ?? undefined}
>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400..700&family=Inter:wght@400..700&display=swap"
    rel="stylesheet"
  />

  <div class="club-page">
    <Container>
      <nav class="club-crumb" aria-label="Breadcrumb">
        <a href="/drivers">← All drivers</a>
      </nav>

      <section class="club-top">
        <div class="club-photo">
          {club.image ? (
            <img src={club.image} alt={club.title} loading="eager" />
          ) : (
            <svg viewBox="0 0 64 64" class="club-photo-fallback" aria-hidden="true">
              <circle cx="32" cy="32" r="30" fill="#fbfcf8"></circle>
              <path d="M 12 46 A 30 30 0 0 0 52 46 A 40 40 0 0 1 12 46 Z" fill="#dde4da" opacity=".7"></path>
            </svg>
          )}
        </div>

        <div class="club-intro">
          <p class="club-kicker">{club.brand.toUpperCase()} · {club.offers.length} RETAILER{club.offers.length === 1 ? '' : 'S'} · AUD</p>
          <h1 class="club-title">{club.title}</h1>
          <p class="club-best">
            <span class="club-best-price">{dollars(best.price)}</span>
            <span class="club-best-at">at {best.name}</span>
          </p>

          <div class="club-ctas">
            <a class="club-cta-buy" href={best.url} rel="nofollow sponsored" target="_blank">
              Go to cheapest store →
            </a>
            <form
              class="club-alert"
              name="price-alert"
              method="POST"
              data-netlify="true"
              data-netlify-honeypot="website"
              data-alert-form
            >
              <input type="hidden" name="form-name" value="price-alert" />
              <input type="hidden" name="club" value={club.title} />
              <label class="club-alert-honeypot" aria-hidden="true">
                Website
                <input type="text" name="website" tabindex="-1" autocomplete="off" />
              </label>
              <input
                type="email"
                name="email"
                required
                placeholder="Email for price alerts"
                aria-label={`Email address for ${club.title} price alerts`}
              />
              <button type="submit">Alert me</button>
              <p class="club-alert-status" data-alert-status role="status" aria-live="polite"></p>
            </form>
          </div>
        </div>
      </section>

      <div class="club-mid">
      <section class="club-chart">
        <PriceChart days={club.days} storeNames={club.storeNames} trackedSince={club.trackedSince} />
      </section>

      <section class="club-stores">
        <h2>Where to buy</h2>
        <div class="club-table-wrap">
          <table>
            <thead>
              <tr><th>Store</th><th class="num">Price</th><th class="num">RRP</th><th>Stock</th><th></th></tr>
            </thead>
            <tbody>
              {club.offers.map((offer, i) => (
                <tr class={i === 0 ? 'is-best' : ''}>
                  <td class="store">{offer.name.toUpperCase()}</td>
                  <td class="num price">
                    {i === 0 ? (
                      <span class="circled">
                        {dollars(offer.price)}
                        <svg viewBox="0 0 140 56" preserveAspectRatio="none" aria-hidden="true">
                          <path d="M 128 26 C 127 9, 98 3, 68 4 C 34 5, 8 12, 7 28 C 6 45, 38 54, 74 52 C 107 50, 133 44, 131 29 C 130 20, 121 13, 110 11" fill="none" stroke="#e8503a" stroke-width="3.4" stroke-linecap="round"></path>
                        </svg>
                      </span>
                    ) : (
                      dollars(offer.price)
                    )}
                  </td>
                  <td class="num rrp">{offer.rrp ? dollars(offer.rrp) : '—'}</td>
                  <td class="stock">{offer.inStock ? 'In stock' : 'Out of stock'}</td>
                  <td class="go"><a href={offer.url} rel="nofollow sponsored" target="_blank">Visit →</a></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
      </div>

      <section class="club-stats">
        <div><span class="stat-label">Lowest seen</span><span class="stat-val">{dollars(club.minEver)}</span></div>
        <div><span class="stat-label">Highest seen</span><span class="stat-val">{dollars(club.maxEver)}</span></div>
        <div><span class="stat-label">Spread today</span><span class="stat-val spread">{spread > 0 ? dollars(spread) : '—'}</span></div>
        <div><span class="stat-label">Days tracked</span><span class="stat-val">{daysTracked}</span></div>
      </section>

      <p class="club-disclaimer">
        Prices are collected nightly from retailer websites (last full check: {auDate(club.days[club.days.length - 1].date)})
        and can change at any time. Always confirm the price on the retailer's site before buying.
      </p>
    </Container>
  </div>
</PageLayout>

<style>
  .club-page {
    --serif: 'Fraunces', Georgia, serif;
    --sans: 'Inter', system-ui, sans-serif;
    background:
      linear-gradient(rgba(6, 23, 15, 0.9), rgba(6, 23, 15, 0.94)),
      url('/images/club-bg.jpg') center / cover no-repeat #071a11;
    color: #f2f4ef;
    padding: 34px 0 90px;
    font-family: var(--sans);
  }

  @media (min-width: 768px) {
    .club-page {
      background-attachment: fixed;
    }
  }

  .club-crumb {
    margin-bottom: 28px;
  }

  .club-crumb a {
    font-family: var(--sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(201, 212, 201, 0.8);
    text-decoration: none;
  }

  .club-crumb a:hover {
    color: #f5c944;
  }

  .club-top {
    display: grid;
    grid-template-columns: minmax(200px, 300px) 1fr;
    gap: 44px;
    align-items: center;
    margin-bottom: 36px;
  }

  @media (max-width: 760px) {
    .club-top {
      grid-template-columns: 1fr;
      gap: 26px;
    }
  }

  .club-mid {
    display: grid;
    grid-template-columns: minmax(0, 11fr) minmax(0, 9fr);
    gap: 18px;
    align-items: start;
    margin-bottom: 8px;
  }

  @media (max-width: 1000px) {
    .club-mid {
      grid-template-columns: 1fr;
    }
  }

  .club-photo {
    aspect-ratio: 1;
    display: grid;
    place-items: center;
    background: #fbfcf8;
    border-radius: 8px;
    overflow: hidden;
  }

  .club-photo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    mix-blend-mode: multiply;
  }

  .club-photo-fallback {
    width: 45%;
    opacity: 0.5;
  }

  .club-kicker {
    margin: 0 0 12px;
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.22em;
    color: rgba(201, 212, 201, 0.85);
  }

  .club-title {
    margin: 0;
    font-family: var(--serif);
    font-optical-sizing: auto;
    font-weight: 560;
    font-size: clamp(32px, 4.6vw, 54px);
    line-height: 1.04;
    letter-spacing: 0.005em;
    color: #f7f8f4;
  }

  .club-best {
    margin: 18px 0 26px;
    display: flex;
    align-items: baseline;
    gap: 14px;
    flex-wrap: wrap;
  }

  .club-best-price {
    font-family: var(--serif);
    font-optical-sizing: auto;
    font-variant-numeric: lining-nums;
    font-weight: 600;
    font-size: clamp(30px, 4vw, 46px);
    color: #f5c944;
  }

  .club-best-at {
    font-family: var(--sans);
    font-size: 14px;
    letter-spacing: 0.01em;
    color: #c9d4c9;
  }

  .club-ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    align-items: stretch;
  }

  .club-cta-buy {
    display: inline-flex;
    align-items: center;
    padding: 14px 24px;
    background: #f5c944;
    color: #0d3527;
    text-decoration: none;
    font-family: var(--sans);
    font-weight: 650;
    font-size: 14px;
    letter-spacing: 0.02em;
    border-radius: 4px;
    transition: all 0.15s ease;
  }

  .club-cta-buy:hover {
    background: #ffd75e;
    transform: translateY(-2px);
  }

  .club-alert {
    position: relative;
    display: flex;
    gap: 0;
    border: 1px solid rgba(245, 201, 68, 0.55);
    border-radius: 4px;
    overflow: hidden;
    background: rgba(7, 30, 20, 0.72);
  }

  .club-alert input[type='email'] {
    width: 210px;
    max-width: 52vw;
    padding: 0 14px;
    background: transparent;
    border: 0;
    outline: 0;
    color: #f2f4ef;
    font-family: var(--sans);
    font-size: 13px;
    letter-spacing: 0.01em;
  }

  .club-alert input[type='email']::placeholder {
    color: rgba(201, 212, 201, 0.6);
  }

  .club-alert button {
    padding: 14px 16px;
    background: transparent;
    border: 0;
    border-left: 1px solid rgba(245, 201, 68, 0.55);
    color: #f5c944;
    font-family: var(--sans);
    font-weight: 650;
    font-size: 13px;
    letter-spacing: 0.02em;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .club-alert button:hover {
    background: #f5c944;
    color: #0d3527;
  }

  .club-alert-honeypot {
    position: absolute;
    left: -10000px;
    top: auto;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .club-alert-status {
    position: absolute;
    left: 0;
    top: 100%;
    margin: 6px 0 0;
    font-family: var(--sans);
    font-size: 12px;
    letter-spacing: 0.01em;
    white-space: nowrap;
  }

  .club-alert-status[data-state='ok'] {
    color: #7fd1ae;
  }

  .club-alert-status[data-state='error'] {
    color: #e8503a;
  }

  .club-stores h2 {
    margin: 0 0 12px;
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(201, 212, 201, 0.85);
  }

  .club-table-wrap {
    overflow-x: auto;
    border: 1px solid rgba(201, 212, 201, 0.24);
    border-radius: 8px;
    background: rgba(6, 23, 15, 0.72);
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
  }

  .club-stores table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
  }

  .club-stores th,
  .club-stores td {
    padding: 11px 14px;
    text-align: left;
    white-space: nowrap;
    border-top: 1px solid rgba(201, 212, 201, 0.14);
  }

  .club-stores thead th {
    border-top: 0;
    font-family: var(--sans);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(201, 212, 201, 0.6);
  }

  .club-stores .num {
    text-align: right;
  }

  .club-stores .store {
    font-family: var(--sans);
    font-weight: 550;
    font-size: 12.5px;
    letter-spacing: 0.06em;
    color: #c9d4c9;
  }

  .club-stores .price {
    font-family: var(--sans);
    font-variant-numeric: tabular-nums;
    font-weight: 650;
    font-size: 15px;
  }

  .club-stores .rrp {
    font-family: var(--sans);
    font-variant-numeric: tabular-nums;
    color: rgba(201, 212, 201, 0.65);
  }

  .club-stores .stock {
    font-family: var(--sans);
    font-size: 11.5px;
    letter-spacing: 0.02em;
    color: #7fd1ae;
  }

  .club-stores tr.is-best {
    background: #0f3d2d;
  }

  .club-stores tr.is-best .store {
    color: #f2f4ef;
  }

  .club-stores tr.is-best .price {
    color: #f5c944;
  }

  .club-stores .circled {
    position: relative;
    display: inline-block;
  }

  .club-stores .circled svg {
    position: absolute;
    inset: -12px -16px;
    width: calc(100% + 32px);
    height: calc(100% + 24px);
    overflow: visible;
    pointer-events: none;
  }

  .club-stores .go a {
    font-family: var(--sans);
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.02em;
    color: #f5c944;
    text-decoration: none;
  }

  .club-stores .go a:hover {
    text-decoration: underline;
  }

  .club-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 14px;
    margin: 26px 0 24px;
  }

  .club-stats > div {
    border: 1px solid rgba(201, 212, 201, 0.24);
    border-radius: 8px;
    padding: 15px 18px;
    background: rgba(6, 23, 15, 0.72);
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .stat-label {
    font-family: var(--sans);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(201, 212, 201, 0.6);
  }

  .stat-val {
    font-family: var(--serif);
    font-optical-sizing: auto;
    font-variant-numeric: lining-nums;
    font-weight: 600;
    font-size: 24px;
    color: #f7f8f4;
  }

  .stat-val.spread {
    color: #7fd1ae;
  }

  .club-disclaimer {
    margin: 0;
    font-family: var(--sans);
    font-size: 12px;
    letter-spacing: 0.01em;
    line-height: 1.7;
    color: rgba(201, 212, 201, 0.6);
  }
</style>

<script>
  // Price-alert signup posts to Netlify Forms without leaving the page.
  const form = document.querySelector<HTMLFormElement>('[data-alert-form]');
  const status = document.querySelector<HTMLParagraphElement>('[data-alert-status]');
  if (form && status) {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const body = new URLSearchParams(new FormData(form) as unknown as Record<string, string>).toString();
      status.dataset.state = '';
      status.textContent = 'Saving…';
      try {
        const res = await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body,
        });
        if (!res.ok) throw new Error();
        status.dataset.state = 'ok';
        status.textContent = "You're on the list — we'll email you when it drops.";
        form.reset();
      } catch {
        status.dataset.state = 'error';
        status.textContent = 'Could not save — please try again.';
      }
    });
  }
</script>
