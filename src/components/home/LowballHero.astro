<script>
  interface Entry {
    t: string;
    s: string;
    rows: [string, number][];
  }

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const fmt = (v: number) =>
    '$' + v.toLocaleString('en-AU', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  const esc = (s: string) =>
    s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

  // Odometer: prices count up from 62% of their target. Skipped for
  // reduced-motion users.
  let odoRaf = 0;
  function runOdometer(delayMs: number) {
    const els = Array.from(document.querySelectorAll<HTMLElement>('.lb-hero [data-odo]'));
    if (!els.length || reduceMotion) return;
    cancelAnimationFrame(odoRaf);
    const targets = els.map((el) => parseFloat(el.dataset.odo || '0'));
    const starts = targets.map((t) => t * 0.62);
    const t0 = performance.now() + delayMs;
    const dur = 1000;
    const tick = (now: number) => {
      const p = Math.min(1, Math.max(0, (now - t0) / dur));
      const e = 1 - Math.pow(1 - p, 3);
      els.forEach((el, i) => {
        el.textContent = fmt(starts[i] + (targets[i] - starts[i]) * e);
      });
      if (p < 1) odoRaf = requestAnimationFrame(tick);
    };
    odoRaf = requestAnimationFrame(tick);
  }
  runOdometer(1150); // timed to the ball landing on first load

  // ---- hero search ----
  const data: Entry[] = JSON.parse(document.getElementById('lb-data')?.textContent || '[]');
  const input = document.getElementById('lbSearch') as HTMLInputElement | null;
  const sug = document.getElementById('lbSug');

  if (data.length && input && sug) {
    const hide = () => {
      sug.hidden = true;
      sug.innerHTML = '';
    };

    const select = (entry: Entry) => {
      hide();
      window.location.href = `/clubs/${entry.s}`;
    };

    let matches: Entry[] = [];
    const search = () => {
      const q = input.value.trim().toUpperCase();
      if (q.length < 2) {
        hide();
        return;
      }
      const starts = data.filter((e) => e.t.startsWith(q));
      const contains = data.filter((e) => !e.t.startsWith(q) && e.t.includes(q));
      matches = [...starts, ...contains].slice(0, 8);
      if (!matches.length) {
        sug.innerHTML = `<span class="lb-sug-none">NO TRACKED CLUB MATCHES "${esc(q)}"</span>`;
        sug.hidden = false;
        return;
      }
      sug.innerHTML = matches
        .map(
          (e, i) =>
            `<button type="button" data-i="${i}"><span>${esc(e.t)}</span><em>FROM ${fmt(e.rows[e.rows.length - 1][1])}</em></button>`
        )
        .join('');
      sug.hidden = false;
    };

    input.addEventListener('input', search);
    input.addEventListener('keydown', (ev) => {
      if (ev.key === 'Enter' && matches.length) {
        ev.preventDefault();
        select(matches[0]);
      } else if (ev.key === 'Escape') {
        hide();
        input.blur();
      }
    });
    sug.addEventListener('mousedown', (ev) => {
      const btn = (ev.target as HTMLElement).closest('button[data-i]');
      if (btn) {
        ev.preventDefault();
        select(matches[Number((btn as HTMLElement).dataset.i)]);
      }
    });
    input.addEventListener('blur', () => {
      // Let a suggestion mousedown win before closing.
      setTimeout(hide, 120);
    });
  }
</script>
