---
// "Today's biggest savings" — the largest same-club price spreads across
// tracked stores, straight from the nightly data. Reuses the club-page
// data layer so the numbers always match the rest of the site.
import { fetchClubs, dollars } from '../../utils/priceData';

const clubs = await fetchClubs();

// Driver-only until the putter/wedge data passes review.
const rows = clubs
  .filter((c) => c.category === 'driver')
  .filter((c) => c.offers.length >= 2)
  .map((c) => {
    const best = c.offers[0];
    const worst = c.offers[c.offers.length - 1];
    return {
      slug: c.slug,
      title: c.title,
      bestPrice: best.price,
      bestStore: best.name,
      worstPrice: worst.price,
      saving: worst.price - best.price,
      stores: c.offers.length,
    };
  })
  .filter((r) => r.saving > 0)
  .sort((a, b) => b.saving - a.saving)
  .slice(0, 8);

const updated = new Date().toLocaleDateString('en-AU', {
  day: 'numeric',
  month: 'long',
  timeZone: 'Australia/Melbourne',
});
---

{rows.length > 0 && (
  <section class="bs" aria-labelledby="bs-heading">
    <div class="bs-inner">
      <p class="bs-kicker">UPDATED NIGHTLY &middot; LAST CHECK {updated.toUpperCase()}</p>
      <h2 class="bs-heading" id="bs-heading">TODAY'S BIGGEST SAVINGS</h2>
      <p class="bs-sub">The same club, priced by every store we track. This is what shopping around is worth right now.</p>

      <ol class="bs-list">
        {rows.map((r, i) => (
          <li>
            <a class="bs-row" href={`/clubs/${r.slug}`}>
              <span class="bs-rank">{String(i + 1).padStart(2, '0')}</span>
              <span class="bs-club">
                <span class="bs-name">{r.title}</span>
                <span class="bs-detail">{dollars(r.bestPrice)} at {r.bestStore.toUpperCase()} &middot; {r.stores} STORES &middot; DEAREST {dollars(r.worstPrice)}</span>
              </span>
              <span class="bs-save">SAVE {dollars(r.saving)}</span>
              <span class="bs-arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ol>

      <div class="bs-cta">
        <a href="/drivers">SEE EVERY DRIVER WE TRACK →</a>
      </div>
    </div>
  </section>
)}

<style>
  .bs {
    background: #092619;
    color: #f2f4ef;
    padding: 84px 20px 92px;
  }

  .bs-inner {
    max-width: 860px;
    margin: 0 auto;
  }

  .bs-kicker {
    margin: 0 0 14px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.26em;
    color: #c9d4c9;
    text-align: center;
  }

  .bs-heading {
    margin: 0;
    font-family: 'Archivo', sans-serif;
    font-weight: 900;
    font-stretch: 72%;
    font-size: clamp(34px, 6vw, 64px);
    line-height: 0.98;
    text-align: center;
    color: #f5c944;
  }

  .bs-sub {
    margin: 16px auto 42px;
    max-width: 520px;
    text-align: center;
    font-family: 'Archivo', sans-serif;
    font-weight: 500;
    font-size: 16px;
    line-height: 1.55;
    color: #c9d4c9;
  }

  .bs-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border: 1px solid rgba(201, 212, 201, 0.28);
    border-radius: 6px;
    overflow: hidden;
    background: rgba(7, 30, 20, 0.5);
  }

  .bs-list li + li {
    border-top: 1px dashed rgba(201, 212, 201, 0.3);
  }

  .bs-row {
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 16px 22px;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s ease;
  }

  .bs-row:hover {
    background: #0f3d2d;
  }

  .bs-rank {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    color: rgba(201, 212, 201, 0.55);
    flex-shrink: 0;
  }

  .bs-club {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .bs-name {
    font-family: 'Archivo', sans-serif;
    font-weight: 800;
    font-stretch: 80%;
    font-size: 17px;
    letter-spacing: 0.04em;
    color: #f2f4ef;
  }

  .bs-row:hover .bs-name {
    color: #f5c944;
  }

  .bs-detail {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.06em;
    color: #c9d4c9;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .bs-save {
    flex-shrink: 0;
    padding: 7px 11px;
    background: #f5c944;
    color: #0d3527;
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.04em;
    transform: rotate(-2deg);
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
  }

  .bs-arrow {
    flex-shrink: 0;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 16px;
    color: rgba(201, 212, 201, 0.6);
    transition: transform 0.15s ease, color 0.15s ease;
  }

  .bs-row:hover .bs-arrow {
    color: #f5c944;
    transform: translateX(4px);
  }

  .bs-cta {
    margin-top: 30px;
    text-align: center;
  }

  .bs-cta a {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.16em;
    color: #f5c944;
    text-decoration: none;
    border-bottom: 1px solid rgba(245, 201, 68, 0.5);
    padding-bottom: 3px;
    transition: border-color 0.15s ease;
  }

  .bs-cta a:hover {
    border-color: #f5c944;
  }

  @media (max-width: 640px) {
    .bs-row {
      flex-wrap: wrap;
      gap: 8px 14px;
      padding: 15px 16px;
    }

    .bs-club {
      flex: 1 1 100%;
      order: -1;
    }

    .bs-detail {
      white-space: normal;
    }
  }
</style>
