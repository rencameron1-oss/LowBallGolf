---
interface Props {
  width?: 'narrow' | 'default' | 'wide' | 'full';
  class?: string;
}

const { width = 'default', class: className = '' } = Astro.props;

const widthClasses = {
  narrow: 'max-w-3xl',
  default: 'max-w-6xl',
  wide: 'max-w-7xl',
  full: 'max-w-full',
};
---

<div class:list={['mx-auto px-4 sm:px-6 lg:px-8', widthClasses[width], className]}>
  <slot />
</div>
