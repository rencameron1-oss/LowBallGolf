---
import SectionHeading from '@bands/ui/components/ui/SectionHeading.astro';

interface Member {
  name?: string;
  role?: string;
  image?: string;
  bio?: string;
  cta_text?: string;
  cta_url?: string;
}

interface Props {
  heading?: string;
  subheading?: string;
  members?: Member[];
}

const {
  heading,
  subheading,
  members = [],
} = Astro.props;
---

{members.length > 0 && (
  <section class="py-20 md:py-28 bg-brand-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {(heading || subheading) && (
        <div class="reveal">
          <SectionHeading heading={heading || ''} subheading={subheading} align="center" />
        </div>
      )}

      <div class:list={[
        'grid gap-8',
        members.length === 1 && 'grid-cols-1 max-w-md mx-auto',
        members.length === 2 && 'grid-cols-1 md:grid-cols-2 max-w-4xl mx-auto',
        members.length === 3 && 'grid-cols-1 md:grid-cols-3',
        members.length >= 4 && 'grid-cols-1 md:grid-cols-2 lg:grid-cols-4',
      ]}>
        {members.map((member, i) => (
          <div class={`reveal reveal-delay-${Math.min(i + 1, 4)}`}>
            <div class="group">
              {member.image && (
                <div class="relative overflow-hidden rounded-2xl aspect-[3/4] mb-5">
                  <img
                    src={member.image}
                    alt={member.name || ''}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                    loading="lazy"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-brand-primary/80 via-transparent to-transparent"></div>
                  <div class="absolute bottom-0 left-0 right-0 p-5">
                    {member.name && (
                      <h3 class="text-xl font-heading font-bold text-brand-champagne">{member.name}</h3>
                    )}
                    {member.role && (
                      <p class="text-sm text-brand-accent">{member.role}</p>
                    )}
                  </div>
                </div>
              )}
              {!member.image && (
                <div class="mb-4">
                  {member.name && (
                    <h3 class="text-xl font-heading font-bold text-brand-champagne">{member.name}</h3>
                  )}
                  {member.role && (
                    <p class="text-sm text-brand-accent">{member.role}</p>
                  )}
                </div>
              )}
              {member.bio && (
                <p class="text-brand-muted text-sm leading-relaxed">{member.bio}</p>
              )}
              {member.cta_text && member.cta_url && (
                <a
                  href={member.cta_url}
                  class="inline-block mt-3 text-sm font-semibold text-brand-accent hover:text-brand-accent-light transition-colors uppercase tracking-wide"
                >
                  {member.cta_text} &rarr;
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
)}
