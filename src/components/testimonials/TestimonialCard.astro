---
import type { CollectionEntry } from 'astro:content';

interface Props {
  testimonial: CollectionEntry<'testimonials'>;
}

const { testimonial } = Astro.props;
const { author_name, author_role, organisation, quote, rating } = testimonial.data;
---

<div class="bg-brand-surface border border-brand-border/50 rounded-2xl p-8 h-full flex flex-col hover:border-brand-accent/30 transition-all duration-300">
  <!-- Quote icon -->
  <svg class="w-8 h-8 text-brand-accent/40 mb-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
    <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11h4v10H0z"/>
  </svg>

  <blockquote class="text-brand-champagne/90 text-lg leading-relaxed italic flex-grow font-heading">
    &ldquo;{quote}&rdquo;
  </blockquote>

  {rating && (
    <div class="flex gap-1 mt-6">
      {Array.from({ length: 5 }, (_, i) => (
        <svg
          class:list={['w-4 h-4', i < rating ? 'text-brand-accent' : 'text-brand-border']}
          fill="currentColor"
          viewBox="0 0 20 20"
        >
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
      ))}
    </div>
  )}

  <div class="mt-4 pt-4 border-t border-brand-border/30">
    <p class="font-semibold text-brand-champagne text-sm">{author_name}</p>
    {(author_role || organisation) && (
      <p class="text-sm text-brand-muted mt-0.5">
        {[author_role, organisation].filter(Boolean).join(', ')}
      </p>
    )}
  </div>
</div>
