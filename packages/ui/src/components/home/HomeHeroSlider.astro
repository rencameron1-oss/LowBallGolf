  .ms-slide-effects {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    overflow: hidden;
  }

  .ms-slide-effect {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .ms-slide-effect--grid {
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.06) 1px, transparent 1px);
    background-size: 7rem 7rem;
    opacity: 0.34;
    mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.86), rgba(0, 0, 0, 0.22));
  }

  .ms-home-slide--light .ms-slide-effect--grid {
    background-image:
      linear-gradient(rgba(9, 9, 11, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(9, 9, 11, 0.08) 1px, transparent 1px);
  }

  .ms-slide-effect--scanlines {
    background-image: repeating-linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.06) 0,
      rgba(255, 255, 255, 0.06) 1px,
      transparent 1px,
      transparent 4px
    );
    opacity: 0.14;
    mix-blend-mode: soft-light;
  }

  .ms-home-slide--light .ms-slide-effect--scanlines {
    background-image: repeating-linear-gradient(
      180deg,
      rgba(9, 9, 11, 0.06) 0,
      rgba(9, 9, 11, 0.06) 1px,
      transparent 1px,
      transparent 4px
    );
  }

  .ms-slide-effect--mobile-glow {
    opacity: 0;
  }

  @keyframes ms-mobile-glow-drift {
    0% {
      transform: translate3d(-4%, -2%, 0) scale(0.96);
      opacity: 0.42;
    }

    50% {
      transform: translate3d(1%, 1%, 0) scale(1.03);
      opacity: 0.58;
    }

    100% {
      transform: translate3d(4%, 2%, 0) scale(1);
      opacity: 0.46;
    }
  }

  .ms-slide-orbs span {
    position: absolute;
    top: var(--orb-top);
    left: var(--orb-left);
    width: var(--orb-size);
    height: var(--orb-size);
    border-radius: 999px;
    background: var(--orb-color);
    filter: blur(68px);
    opacity: 0.86;
    animation: ms-orb-drift 12s ease-in-out infinite alternate;
  }

  .ms-slide-particles span {
    position: absolute;
    top: var(--particle-top);
    left: var(--particle-left);
    width: var(--particle-size);
    height: var(--particle-size);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.52);
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.04);
    opacity: 0.38;
