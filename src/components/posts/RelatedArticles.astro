---
import { getCollection } from 'astro:content';
import SectionHeading from '@bands/ui/components/ui/SectionHeading.astro';
import { formatDate } from '../../utils/dates';

interface Props {
  relatedSlugs?: string[];
  currentSlug: string;
}

const { relatedSlugs = [], currentSlug } = Astro.props;

const allPosts = await getCollection('posts');
const relatedPosts = relatedSlugs
  .map((slug) => allPosts.find((p) => p.id === slug))
  .filter((p): p is NonNullable<typeof p> => p != null && p.id !== currentSlug && !p.data.draft)
  .slice(0, 3);
---

{relatedPosts.length > 0 && (
  <section class="mt-16 pt-12 border-t border-brand-border/30">
    <SectionHeading heading="Related Articles" align="left" />
    <div class="grid gap-6 md:grid-cols-3 mt-6">
      {relatedPosts.map((post) => (
        <a
          href={`/posts/${post.id}`}
          class="group block bg-brand-surface rounded-xl overflow-hidden border border-brand-border/20 hover:border-brand-accent/40 transition-colors"
        >
          {post.data.hero_image && (
            <img
              src={post.data.hero_image}
              alt={post.data.title}
              class="w-full h-40 object-cover"
            />
          )}
          <div class="p-4">
            <p class="text-xs text-brand-muted uppercase tracking-wide">
              {formatDate(post.data.pubDate)}
            </p>
            <h3 class="text-base font-semibold text-brand-text mt-1 group-hover:text-brand-accent transition-colors line-clamp-2">
              {post.data.title}
            </h3>
            {post.data.excerpt && (
              <p class="text-sm text-brand-muted mt-2 line-clamp-2">{post.data.excerpt}</p>
            )}
          </div>
        </a>
      ))}
    </div>
  </section>
)}
