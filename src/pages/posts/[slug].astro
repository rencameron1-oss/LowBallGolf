---
import { getCollection, getEntry, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import StructuredData from '../../components/seo/StructuredData.astro';
import TinaVisualEditing from '../../components/tina/TinaVisualEditing.astro';
import BlockRenderer from '../../components/blocks/BlockRenderer.astro';
import RelatedArticles from '../../components/posts/RelatedArticles.astro';
import { formatDate } from '../../utils/dates';
import siteConfig from '../../config/site';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.id },
  }));
}

const { slug } = Astro.params;
const post = slug ? await getEntry('posts', slug) : undefined;

if (!post) {
  throw new Error(`Post not found: ${slug}`);
}

const { Content } = await render(post);

const breadcrumbData = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteConfig.url },
    { '@type': 'ListItem', position: 2, name: 'Guides', item: `${siteConfig.url}/guides` },
    { '@type': 'ListItem', position: 3, name: post.data.title },
  ],
};

const articleData = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.seo_description || post.data.excerpt || '',
  datePublished: post.data.pubDate.toISOString(),
  ...(post.data.updatedDate && { dateModified: post.data.updatedDate.toISOString() }),
  author: {
    '@type': post.data.author ? 'Person' : 'Organization',
    name: post.data.author || siteConfig.name,
    url: siteConfig.url,
  },
  publisher: {
    '@type': 'Organization',
    name: siteConfig.name,
    url: siteConfig.url,
    ...(siteConfig.logo.icon && {
      logo: {
        '@type': 'ImageObject',
        url: new URL(siteConfig.logo.icon, siteConfig.url).toString(),
      },
    }),
  },
  mainEntityOfPage: new URL(`/posts/${post.id}`, siteConfig.url).toString(),
  ...(post.data.hero_image && {
    image: new URL(post.data.hero_image, siteConfig.url).toString(),
  }),
};
---

<PostLayout
  title={post.data.seo_title || post.data.title}
  description={post.data.seo_description || post.data.excerpt}
  ogImage={post.data.hero_image}
  publishedTime={post.data.pubDate.toISOString()}
  modifiedTime={post.data.updatedDate?.toISOString()}
  author={post.data.author}
  tags={post.data.tags}
>
  <TinaVisualEditing collection="post" relativePath={`${post.id}.md`} />
  <StructuredData data={articleData} />
  <StructuredData data={breadcrumbData} />

  <header class="mb-8">
    <p class="text-sm text-brand-muted uppercase tracking-wide">
      {formatDate(post.data.pubDate)}
      {post.data.category && ` · ${post.data.category}`}
    </p>
    <h1 class="text-3xl md:text-5xl font-heading font-semibold text-brand-text mt-3 tracking-tight">
      {post.data.title}
    </h1>
    {post.data.author && (
      <p class="text-brand-muted mt-2">By {post.data.author}</p>
    )}
  </header>

  {post.data.hero_image && (
    <img
      src={post.data.hero_image}
      alt={post.data.title}
      class="w-full rounded-xl mb-8"
    />
  )}

  <div class="prose prose-lg max-w-none">
    <Content />
  </div>

  {post.data.blocks && post.data.blocks.length > 0 && (
    <BlockRenderer blocks={post.data.blocks} />
  )}

  <RelatedArticles relatedSlugs={post.data.related_posts} currentSlug={post.id} />
</PostLayout>
