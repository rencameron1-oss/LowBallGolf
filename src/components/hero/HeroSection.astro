---
import Button from '../ui/Button.astro';

interface Props {
  heading: string;
  subheading?: string;
  image?: string;
  ctaText?: string;
  ctaUrl?: string;
  overlay?: boolean;
  imageLayout?: 'cover' | 'portrait';
}

const {
  heading,
  subheading,
  image,
  ctaText,
  ctaUrl,
  overlay = true,
  imageLayout = 'cover',
} = Astro.props;

const isPortrait = imageLayout === 'portrait' && !!image;
---

{isPortrait ? (
  <section class="relative overflow-hidden -mt-18 md:-mt-20 border-b border-brand-border/60 bg-gradient-to-b from-brand-surface-alt via-brand-primary to-brand-primary">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-28 md:pt-32 pb-16 md:pb-24 grid grid-cols-1 md:grid-cols-2 items-center gap-10 md:gap-16">
      <div class="order-2 md:order-1 text-center md:text-left">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-semibold text-brand-text leading-tight tracking-tight">
          {heading}
        </h1>
        {subheading && (
          <p class="mt-4 md:mt-6 text-lg md:text-xl text-brand-muted font-body leading-relaxed">
            {subheading}
          </p>
        )}
        {ctaText && ctaUrl && (
          <div class="mt-8">
            <Button href={ctaUrl} size="lg">
              {ctaText}
            </Button>
          </div>
        )}
      </div>
      <div class="order-1 md:order-2 mx-auto w-full max-w-sm md:max-w-md">
        <div class="aspect-square w-full rounded-2xl overflow-hidden shadow-xl ring-1 ring-brand-border/60">
          <img
            src={image}
            alt={heading}
            class="w-full h-full object-cover object-center"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>
) : (
  <section class="relative min-h-[46vh] md:min-h-[54vh] flex items-center justify-center overflow-hidden -mt-18 md:-mt-20 border-b border-brand-border/60">
    {image && (
      <div class="absolute inset-0">
        <img
          src={image}
          alt=""
          class="w-full h-full object-cover hero-bg"
          loading="eager"
        />
        {overlay && (
          <>
            <div class="absolute inset-0 bg-gradient-to-b from-brand-primary/88 via-brand-primary/68 to-brand-primary"></div>
            <div class="absolute inset-0 bg-gradient-to-r from-brand-primary/72 via-brand-primary/38 to-brand-primary/72"></div>
          </>
        )}
      </div>
    )}

    {!image && (
      <div class="absolute inset-0 bg-gradient-to-b from-brand-surface-alt via-brand-primary to-brand-primary"></div>
    )}

    <div class="relative z-10 text-center px-4 sm:px-6 lg:px-8 max-w-5xl mx-auto pt-20">
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-heading font-semibold text-brand-text leading-tight tracking-tight">
        {heading}
      </h1>
      {subheading && (
        <p class="mt-4 md:mt-6 text-lg md:text-xl lg:text-2xl text-brand-muted max-w-3xl mx-auto font-body leading-relaxed">
          {subheading}
        </p>
      )}
      {ctaText && ctaUrl && (
        <div class="mt-10">
          <Button href={ctaUrl} size="lg">
            {ctaText}
          </Button>
        </div>
      )}
    </div>
  </section>
)}
