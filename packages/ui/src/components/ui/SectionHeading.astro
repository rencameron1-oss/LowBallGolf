---
interface Props {
  kicker?: string;
  heading: string;
  subheading?: string;
  align?: 'left' | 'center';
  inverted?: boolean;
}

const { kicker, heading, subheading, align = 'left', inverted = false } = Astro.props;

const alignClass = align === 'center' ? 'text-center' : 'text-left';
const kickerColor = inverted ? 'text-brand-accent-light' : 'text-brand-accent/80';
const headingColor = inverted ? 'text-white' : 'text-brand-text';
const subheadingColor = inverted ? 'text-white/70' : 'text-brand-muted';
---

<div class:list={['mb-12', alignClass]}>
  {kicker && (
    <p class:list={['text-sm font-semibold uppercase tracking-[0.22em]', kickerColor, align === 'center' && 'mx-auto']}>
      {kicker}
    </p>
  )}
  <h2 class:list={['text-3xl md:text-5xl font-heading font-semibold tracking-tight', headingColor]}>
    {heading}
  </h2>
  <div class:list={['accent-line mt-4 mb-4', align === 'center' && 'mx-auto']}></div>
  {subheading && (
    <p class:list={['mt-3 text-lg max-w-2xl leading-relaxed', subheadingColor, align === 'center' && 'mx-auto']}>
      {subheading}
    </p>
  )}
</div>
