---
import siteConfig from '../../config/site';
import BrandMark from './BrandMark.astro';
import { getSiteSettings } from '../../utils/siteSettings';

interface Props {
  theme?: 'light' | 'dark';
}

const { theme = 'light' } = Astro.props;
const isDark = theme === 'dark';

const siteSettings = getSiteSettings();
const footerNote = siteSettings.footer_note;
---

<footer class:list={[isDark ? 'footer-dark' : 'bg-brand-surface border-t border-brand-border/70']}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="md:col-span-2">
        <a href="/" class="inline-block">
          <BrandMark theme={theme} size="footer" class={isDark ? 'text-white' : 'text-brand-text'} />
        </a>
        <p class:list={['text-sm leading-relaxed max-w-md mt-4', isDark ? 'text-white/68' : 'text-brand-muted']}>
          {siteConfig.tagline}
        </p>
        <!-- Social Icons -->
        <div class="flex gap-4 mt-6">
          {siteConfig.social.facebook && (
            <a href={siteConfig.social.facebook} target="_blank" rel="noopener noreferrer" class:list={['w-10 h-10 rounded-full flex items-center justify-center transition-all duration-300', isDark ? 'footer-social-dark' : 'border border-brand-border/70 text-brand-muted hover:text-brand-accent hover:border-brand-accent']} aria-label="Facebook">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          )}
          {siteConfig.social.instagram && (
            <a href={siteConfig.social.instagram} target="_blank" rel="noopener noreferrer" class:list={['w-10 h-10 rounded-full flex items-center justify-center transition-all duration-300', isDark ? 'footer-social-dark' : 'border border-brand-border/70 text-brand-muted hover:text-brand-accent hover:border-brand-accent']} aria-label="Instagram">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
          )}
          {siteConfig.social.youtube && (
            <a href={siteConfig.social.youtube} target="_blank" rel="noopener noreferrer" class:list={['w-10 h-10 rounded-full flex items-center justify-center transition-all duration-300', isDark ? 'footer-social-dark' : 'border border-brand-border/70 text-brand-muted hover:text-brand-accent hover:border-brand-accent']} aria-label="YouTube">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            </a>
          )}
          {siteConfig.social.tiktok && (
            <a href={siteConfig.social.tiktok} target="_blank" rel="noopener noreferrer" class:list={['w-10 h-10 rounded-full flex items-center justify-center transition-all duration-300', isDark ? 'footer-social-dark' : 'border border-brand-border/70 text-brand-muted hover:text-brand-accent hover:border-brand-accent']} aria-label="TikTok">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86 4.43v-7.15a8.16 8.16 0 005.58 2.09V11.1a4.84 4.84 0 01-3.77-1.85v-2.56z"/></svg>
            </a>
          )}
          <a href={`mailto:${siteConfig.social.email}`} class:list={['w-10 h-10 rounded-full flex items-center justify-center transition-all duration-300', isDark ? 'footer-social-dark' : 'border border-brand-border/70 text-brand-muted hover:text-brand-accent hover:border-brand-accent']} aria-label="Email">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class:list={['text-sm font-semibold uppercase tracking-widest mb-5', isDark ? 'text-white' : 'text-brand-text']}>
          Quick Links
        </h4>
        <ul class="space-y-3">
          <li><a href="/drivers" class:list={['text-sm transition-colors duration-300', isDark ? 'text-white/68 hover:text-white' : 'text-brand-muted hover:text-brand-accent']}>Driver Prices</a></li>
          <li><a href="/guides" class:list={['text-sm transition-colors duration-300', isDark ? 'text-white/68 hover:text-white' : 'text-brand-muted hover:text-brand-accent']}>Guides</a></li>
          <li><a href="/about" class:list={['text-sm transition-colors duration-300', isDark ? 'text-white/68 hover:text-white' : 'text-brand-muted hover:text-brand-accent']}>About</a></li>
          <li><a href="/contact" class:list={['text-sm transition-colors duration-300', isDark ? 'text-white/68 hover:text-white' : 'text-brand-muted hover:text-brand-accent']}>Contact</a></li>
        </ul>
      </div>

      <!-- Tracked stores -->
      <div>
        <h4 class:list={['text-sm font-semibold uppercase tracking-widest mb-5', isDark ? 'text-white' : 'text-brand-text']}>
          We Track
        </h4>
        <ul class="space-y-3">
          <li><span class:list={['text-sm', isDark ? 'text-white/68' : 'text-brand-muted']}>Drummond Golf</span></li>
          <li><span class:list={['text-sm', isDark ? 'text-white/68' : 'text-brand-muted']}>Power Golf</span></li>
          <li><span class:list={['text-sm', isDark ? 'text-white/68' : 'text-brand-muted']}>Golf Paradise</span></li>
          <li><span class:list={['text-sm', isDark ? 'text-white/68' : 'text-brand-muted']}>The Golf Factory &amp; House of Golf</span></li>
          <li><a href="/contact" class:list={['text-sm transition-colors duration-300 font-medium', isDark ? 'footer-cta-dark' : 'text-brand-accent hover:text-brand-accent-light']}>Suggest a store</a></li>
        </ul>
      </div>
    </div>

    <div class:list={['mt-12 pt-8 flex flex-col md:flex-row items-center justify-between gap-4', isDark ? 'border-t border-white/10' : 'border-t border-brand-border/70']}>
      <p class:list={['text-xs', isDark ? 'text-white/54' : 'text-brand-muted']}>
        &copy; {new Date().getFullYear()} {siteConfig.name}. All rights reserved.
      </p>
      <p class:list={['text-xs', isDark ? 'text-white/54' : 'text-brand-muted']}>
        {footerNote}
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-dark {
    background: var(--color-brand-dark-surface);
    border-top: 1px solid var(--color-brand-dark-border);
  }

  .footer-social-dark {
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.68);
  }

  .footer-social-dark:hover {
    color: white;
    border-color: var(--color-brand-dark-accent);
  }

  .footer-cta-dark {
    color: var(--color-brand-dark-accent-light);
  }

  .footer-cta-dark:hover {
    color: white;
  }
</style>
