---
// LowballGolf homepage hero, implemented from the Claude Design comp
// "LowballGolf Hero.dc.html". Fairway photo backdrop (Cristina Anne
// Costello via Unsplash, free license) under a green tint, condensed
// wordmark whose second O is a golf ball that flies in along a dotted
// trail, and a price-ticket card showing a real club's spread, fetched
// from Supabase at build time. Falls back to a fictional demo card when
// the database is unreachable so the build never breaks.

interface HeroRow {
  store: string;
  price: number;
}

interface HeroCard {
  title: string;
  meta: string;
  rows: HeroRow[]; // sorted dearest-first; the last row is the best price
  spread: number;
}

const fallbackCard: HeroCard = {
  title: 'PING G440K DRIVER',
  meta: '3 RETAILERS · AUD',
  rows: [
    { store: 'FAIRWAY DIRECT', price: 1199.95 },
    { store: 'PRO SHOP CENTRAL', price: 1149.0 },
    { store: 'BIRDIE SUPPLY CO.', price: 1019.96 },
  ],
  spread: 179.99,
};

let card = fallbackCard;

const SUPABASE_URL = import.meta.env.SUPABASE_URL;
const SUPABASE_ANON_KEY = import.meta.env.SUPABASE_ANON_KEY;

if (SUPABASE_URL && SUPABASE_ANON_KEY) {
  try {
    const get = async (path: string) => {
      const res = await fetch(`${SUPABASE_URL}/rest/v1/${path}`, {
        headers: { apikey: SUPABASE_ANON_KEY },
      });
      if (!res.ok) throw new Error(`${path} -> ${res.status}`);
      return res.json();
    };

    // The most persuasive real example: biggest spread among clubs
    // stocked by 3+ stores.
    const [best] = await get(
      'product_best_price?select=*&retailer_count=gte.3&order=spread.desc&limit=1'
    );
    if (best) {
      const listings: { retailers: { name: string }; prices: { price: number } | null }[] =
        await get(
          `listings?select=retailers(name),prices(price)&product_id=eq.${best.product_id}` +
            '&active=is.true&in_stock=is.true&match_status=in.(auto,confirmed)'
        );
      // One row per retailer at its cheapest listing.
      const perStore = new Map<string, number>();
      for (const l of listings) {
        if (!l.prices) continue;
        const name = l.retailers.name.toUpperCase();
        const price = Number(l.prices.price);
        if (!perStore.has(name) || price < perStore.get(name)!) perStore.set(name, price);
      }
      const sorted = [...perStore.entries()]
        .map(([store, price]) => ({ store, price }))
        .sort((a, b) => b.price - a.price);
      if (sorted.length >= 3) {
        // Dearest, middle, cheapest — three rows like the design.
        const rows = [sorted[0], sorted[Math.floor(sorted.length / 2)], sorted[sorted.length - 1]];
        card = {
          title: `${best.brand} ${best.model} DRIVER`.toUpperCase(),
          meta: `${best.retailer_count} RETAILERS · AUD`,
          rows,
          spread: Number(best.spread),
        };
      }
    }
  } catch {
    // keep fallbackCard
  }
}

const dollars = (n: number) =>
  '$' + n.toLocaleString('en-AU', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

const bestRow = card.rows[card.rows.length - 1];
const normalRows = card.rows.slice(0, -1);
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
<link
  href="https://fonts.googleapis.com/css2?family=Archivo:wdth,wght@62..125,400..900&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
  rel="stylesheet"
/>

<div class="lb-hero" data-hero>
  <p class="lb-kicker">GOLF EQUIPMENT PRICE COMPARISON &middot; AUSTRALIA</p>

  <h1 class="lb-wordmark">
    <span class="lb-word lb-gold" style="animation-delay:.85s">LOWBALL</span><span class="lb-word" style="animation-delay:.95s">G</span><span class="lb-ball-slot">
      <svg class="lb-trail" viewBox="0 0 1000 400" preserveAspectRatio="none">
        <path
          d="M 0 16 C 320 110, 560 220, 700 330 C 728 351, 744 360, 758 366 C 786 300, 828 296, 860 338 C 880 364, 934 384, 995 392"
          fill="none" stroke="#f5c944" stroke-width="5" stroke-linecap="round"
          stroke-dasharray="1 15" pathLength="500"></path>
      </svg>
      <span class="lb-flight">
        <span class="lb-float">
          <svg class="lb-ball" viewBox="0 0 64 64">
            <circle cx="32" cy="32" r="30" fill="#fbfcf8"></circle>
            <path d="M 12 46 A 30 30 0 0 0 52 46 A 40 40 0 0 1 12 46 Z" fill="#dde4da" opacity=".7"></path>
            <g fill="#b9c6b9" opacity=".75">
              <circle cx="24" cy="16" r="1.8"></circle><circle cx="32" cy="16" r="1.8"></circle><circle cx="40" cy="16" r="1.8"></circle>
              <circle cx="20" cy="23" r="1.8"></circle><circle cx="28" cy="23" r="1.8"></circle><circle cx="36" cy="23" r="1.8"></circle><circle cx="44" cy="23" r="1.8"></circle>
              <circle cx="16" cy="30" r="1.8"></circle><circle cx="24" cy="30" r="1.8"></circle><circle cx="32" cy="30" r="1.8"></circle><circle cx="40" cy="30" r="1.8"></circle><circle cx="48" cy="30" r="1.8"></circle>
              <circle cx="20" cy="37" r="1.8"></circle><circle cx="28" cy="37" r="1.8"></circle><circle cx="36" cy="37" r="1.8"></circle><circle cx="44" cy="37" r="1.8"></circle>
              <circle cx="24" cy="44" r="1.8"></circle><circle cx="32" cy="44" r="1.8"></circle><circle cx="40" cy="44" r="1.8"></circle>
            </g>
          </svg>
        </span>
      </span>
    </span><span class="lb-word" style="animation-delay:1.05s">LF</span>
  </h1>

  <div class="lb-card">
    <div class="lb-card-head">
      <span class="lb-card-title">{card.title}</span>
      <span class="lb-card-meta">{card.meta}</span>
    </div>
    {normalRows.map((row) => (
      <div class="lb-row">
        <span class="lb-store">{row.store}</span>
        <span class="lb-price" data-odo={String(row.price)}>{dollars(row.price)}</span>
      </div>
    ))}
    <div class="lb-row lb-row-best">
      <span class="lb-store lb-store-best">{bestRow.store}</span>
      <span class="lb-best-wrap">
        <span class="lb-price lb-price-best" data-odo={String(bestRow.price)}>{dollars(bestRow.price)}</span>
        <svg class="lb-circle" viewBox="0 0 140 56" preserveAspectRatio="none">
          <path
            d="M 128 26 C 127 9, 98 3, 68 4 C 34 5, 8 12, 7 28 C 6 45, 38 54, 74 52 C 107 50, 133 44, 131 29 C 130 20, 121 13, 110 11"
            fill="none" stroke="#e8503a" stroke-width="3.4" stroke-linecap="round"
            pathLength="100" stroke-dasharray="100" stroke-dashoffset="0"></path>
        </svg>
      </span>
      <span class="lb-tag-pos" id="tagPos">
        <span class="lb-tag">SPREAD: {dollars(card.spread)}</span>
      </span>
    </div>
  </div>

  <p class="lb-tagline">Same club. Different price. <span class="lb-gold-text">Play the low ball.</span></p>

  <div class="lb-cta-wrap">
    <a href="/drivers" class="lb-cta">START COMPARING</a>
  </div>
</div>

<style is:global>
  @keyframes om-flight {
    0% { transform: translate(-78vw, -24vh) scale(1); }
    52% { transform: translate(-15vw, -1vh) scale(1); }
    60% { transform: translate(-11vw, 2px) scale(1.16, 0.8); }
    68% { transform: translate(-6.5vw, -8vh) scale(1, 1); }
    78% { transform: translate(-3.2vw, 2px) scale(1.08, 0.9); }
    100% { transform: translate(0, 0) scale(1); }
  }
  @keyframes om-spin { from { transform: rotate(-540deg); } }
  @keyframes om-float { 50% { transform: translateY(-3px); } }
  @keyframes om-trail { 0% { opacity: 0; } 8% { opacity: 0.85; } 55% { opacity: 0.85; } 100% { opacity: 0; } }
  @keyframes om-fadeup { from { opacity: 0; transform: translateY(14px); } }
  @keyframes om-cardin { from { opacity: 0; transform: translateY(10px); } }
  @keyframes om-draw { from { stroke-dashoffset: 101; } }
  @keyframes om-lift { from { transform: translateY(0); box-shadow: none; background: transparent; } }
  @keyframes om-stamp {
    from { opacity: 0; transform: scale(1.9) rotate(-14deg); }
    60% { opacity: 1; transform: scale(0.95) rotate(0deg); }
    to { transform: scale(1) rotate(-4deg); }
  }

  .lb-hero {
    min-height: 100vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 140px 20px 72px;
    box-sizing: border-box;
    background:
      radial-gradient(120% 90% at 50% 28%, rgba(13, 53, 39, 0.62) 0%, rgba(9, 38, 25, 0.86) 78%),
      url('/images/hero-fairway.jpg') center / cover no-repeat #092619;
    color: #f2f4ef;
    text-align: center;
    /* Pull the hero up behind the fixed translucent header so the photo
       runs underneath it (the layout inserts a spacer we must cancel). */
    margin-top: calc(-4.5rem - max(env(safe-area-inset-top), 0.7rem));
  }

  @media (min-width: 768px) {
    .lb-hero {
      margin-top: calc(-5rem - max(env(safe-area-inset-top), 0rem));
    }
  }

  .lb-kicker {
    animation: om-fadeup 0.5s ease-out 0.85s backwards;
    margin: 0 0 18px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.28em;
    color: #c9d4c9;
  }

  .lb-wordmark {
    margin: 0;
    font-family: 'Archivo', sans-serif;
    font-weight: 900;
    font-stretch: 72%;
    font-size: clamp(52px, 10.5vw, 132px);
    line-height: 0.95;
    letter-spacing: 0.005em;
    white-space: nowrap;
    color: #f2f4ef;
  }

  .lb-word { animation: om-fadeup 0.5s ease-out backwards; }
  .lb-gold { color: #f5c944; }
  .lb-gold-text { color: #f5c944; }

  .lb-ball-slot {
    position: relative;
    display: inline-block;
    width: 0.68em;
    height: 0.68em;
    vertical-align: -0.012em;
  }

  .lb-trail {
    position: absolute;
    right: 0.3em;
    bottom: 0.22em;
    width: 76vw;
    height: 32vh;
    overflow: visible;
    pointer-events: none;
    opacity: 0;
    animation: om-trail 1.9s linear both;
  }

  .lb-flight {
    position: absolute;
    inset: 0;
    transform-origin: 50% 100%;
    animation: om-flight 1.2s cubic-bezier(0.3, 0.6, 0.45, 1) backwards;
  }

  .lb-float {
    position: absolute;
    inset: 0;
    animation: om-float 2.8s ease-in-out 4.4s infinite;
  }

  .lb-ball {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    transform-origin: 50% 50%;
    animation: om-spin 1.2s ease-out backwards;
  }

  .lb-card {
    animation: om-cardin 0.45s ease-out 1.1s backwards;
    width: min(560px, 92vw);
    margin-top: 44px;
    border: 1px solid rgba(201, 212, 201, 0.28);
    border-radius: 6px;
    text-align: left;
  }

  .lb-card-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    padding: 14px 18px;
  }

  .lb-card-title {
    font-family: 'Archivo', sans-serif;
    font-weight: 800;
    font-stretch: 80%;
    font-size: 17px;
    letter-spacing: 0.06em;
  }

  .lb-card-meta {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    color: #c9d4c9;
  }

  .lb-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    padding: 14px 18px;
    border-top: 1px dashed rgba(201, 212, 201, 0.35);
  }

  .lb-store {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 14px;
    letter-spacing: 0.08em;
    color: #c9d4c9;
  }

  .lb-price {
    font-family: 'IBM Plex Mono', monospace;
    font-variant-numeric: tabular-nums;
    font-weight: 500;
    font-size: 20px;
    color: #f2f4ef;
  }

  .lb-row-best {
    position: relative;
    padding: 16px 18px;
    border-radius: 0 0 6px 6px;
    transform: translateY(-3px);
    background: #0f3d2d;
    box-shadow: 0 12px 26px rgba(0, 0, 0, 0.38);
    animation: om-lift 0.35s ease-out 2.55s backwards;
  }

  .lb-store-best { color: #f2f4ef; }

  .lb-best-wrap { position: relative; display: inline-block; }

  .lb-price-best { font-weight: 600; color: #f5c944; }

  .lb-circle {
    position: absolute;
    inset: -15px -20px;
    width: calc(100% + 40px);
    height: calc(100% + 30px);
    overflow: visible;
    pointer-events: none;
  }

  .lb-circle path { animation: om-draw 0.55s ease-in-out 2.3s backwards; }

  .lb-tag-pos {
    position: absolute;
    top: 50%;
    left: 100%;
    margin-left: 18px;
    transform: translateY(-50%);
  }

  .lb-tag {
    display: inline-block;
    white-space: nowrap;
    padding: 8px 12px;
    background: #f5c944;
    color: #0d3527;
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.06em;
    box-shadow: 0 6px 14px rgba(0, 0, 0, 0.3);
    transform: rotate(-4deg);
    animation: om-stamp 0.4s ease-out 3s backwards;
  }

  .lb-tagline {
    animation: om-fadeup 0.5s ease-out 3.35s backwards;
    margin: 36px 0 0;
    font-family: 'Archivo', sans-serif;
    font-weight: 500;
    font-size: clamp(16px, 2.2vw, 21px);
    color: #f2f4ef;
  }

  .lb-cta-wrap {
    animation: om-fadeup 0.5s ease-out 3.55s backwards;
    margin-top: 24px;
  }

  .lb-cta {
    display: inline-block;
    padding: 16px 34px;
    background: #f5c944;
    color: #0d3527;
    text-decoration: none;
    font-family: 'Archivo', sans-serif;
    font-weight: 900;
    font-stretch: 80%;
    font-size: 17px;
    letter-spacing: 0.1em;
    border-radius: 4px;
    transition: all 0.15s ease;
  }

  .lb-cta:hover {
    background: #ffd75e;
    transform: translateY(-2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .lb-hero * { animation: none !important; }
  }

  @media (max-width: 640px) {
    .lb-row { flex-direction: column; align-items: flex-start; gap: 4px; }
    .lb-row .lb-price { font-size: 22px; }
    .lb-tag-pos { top: auto; bottom: 12px; left: auto; right: 12px; margin-left: 0; transform: none; }
    .lb-card { width: min(440px, 94vw); }
  }
</style>

<script>
  // Odometer: prices count up from 62% of their target, starting as the
  // ball lands. Skipped entirely for reduced-motion users.
  const els = Array.from(document.querySelectorAll<HTMLElement>('.lb-hero [data-odo]'));
  const fmt = (v: number) =>
    '$' + v.toLocaleString('en-AU', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

  if (els.length && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const targets = els.map((el) => parseFloat(el.dataset.odo || '0'));
    const starts = targets.map((t) => t * 0.62);
    const t0 = performance.now() + 1150;
    const dur = 1000;
    const tick = (now: number) => {
      const p = Math.min(1, Math.max(0, (now - t0) / dur));
      const e = 1 - Math.pow(1 - p, 3);
      els.forEach((el, i) => {
        el.textContent = fmt(starts[i] + (targets[i] - starts[i]) * e);
      });
      if (p < 1) requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  }
</script>
