<script>
  const msHeroSliders = Array.from(document.querySelectorAll('[data-ms-hero-slider]'));

  msHeroSliders.forEach((msHeroSlider) => {
    if (!(msHeroSlider instanceof HTMLElement)) {
      return;
    }

    const slides = Array.from(msHeroSlider.querySelectorAll('[data-ms-slide]'));
    const copies = Array.from(msHeroSlider.querySelectorAll('[data-ms-copy]'));
    const controls = Array.from(msHeroSlider.querySelectorAll('[data-ms-control]'));
    const previousArrow = msHeroSlider.querySelector('[data-ms-arrow-prev]');
    const nextArrow = msHeroSlider.querySelector('[data-ms-arrow-next]');
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const autoplaySeconds = Number(msHeroSlider.dataset.autoplaySeconds || 0);
    const pauseReasons = new Set();
    let currentIndex = controls.findIndex((control) => control.getAttribute('aria-selected') === 'true');
    let autoplayTimer = 0;

    if (currentIndex < 0) {
      currentIndex = 0;
    }

    const syncArrowState = (nextIndex) => {
      if (previousArrow instanceof HTMLButtonElement) {
        previousArrow.disabled = nextIndex <= 0;
      }

      if (nextArrow instanceof HTMLButtonElement) {
        nextArrow.disabled = nextIndex >= slides.length - 1;
      }
    };

    const syncSlideState = (nextIndex) => {
      slides.forEach((slide, index) => {
        const isActive = index === nextIndex;
        slide.dataset.active = isActive ? 'true' : 'false';
        slide.setAttribute('aria-hidden', isActive ? 'false' : 'true');
      });

      copies.forEach((copy, index) => {
        copy.dataset.active = index === nextIndex ? 'true' : 'false';
      });

      controls.forEach((control, index) => {
        const isActive = index === nextIndex;
        control.dataset.active = isActive ? 'true' : 'false';
        control.setAttribute('aria-selected', isActive ? 'true' : 'false');
        control.tabIndex = isActive ? 0 : -1;
      });

      syncArrowState(nextIndex);
      msHeroSlider.dataset.theme = slides[nextIndex]?.dataset.theme || 'dark';
    };

    const stopAutoplay = () => {
      window.clearTimeout(autoplayTimer);
    };

    const getSlideDuration = (index) => {
      const slideDuration = Number(slides[index]?.dataset.durationSeconds || autoplaySeconds || 0);

      return Number.isFinite(slideDuration) ? slideDuration : 0;
    };

    const queueAutoplay = () => {
      stopAutoplay();

      const activeSlideDuration = getSlideDuration(currentIndex);

      if (prefersReducedMotion || activeSlideDuration <= 0 || slides.length < 2 || pauseReasons.size > 0) {
        return;
      }

      autoplayTimer = window.setTimeout(() => {
        setActive((currentIndex + 1) % slides.length, false);
      }, activeSlideDuration * 1000);
    };

    const pauseAutoplay = (reason) => {
      pauseReasons.add(reason);
      stopAutoplay();
    };

    const resumeAutoplay = (reason) => {
      pauseReasons.delete(reason);
      queueAutoplay();
    };

    const setActive = (nextIndex, moveFocus = false) => {
      const clampedIndex = Math.min(slides.length - 1, Math.max(0, nextIndex));
      currentIndex = clampedIndex;
      syncSlideState(clampedIndex);

      if (moveFocus && controls[clampedIndex] instanceof HTMLElement) {
        controls[clampedIndex].focus();
      }

      queueAutoplay();
    };

    const goRelative = (delta, moveFocus = false) => {
      const nextIndex = Math.min(slides.length - 1, Math.max(0, currentIndex + delta));

      if (nextIndex === currentIndex) {
        syncArrowState(currentIndex);
        return;
      }

      setActive(nextIndex, moveFocus);
    };

    controls.forEach((control, index) => {
      control.addEventListener('click', () => setActive(index, false));
    });

    if (previousArrow instanceof HTMLButtonElement) {
      previousArrow.addEventListener('click', () => goRelative(-1, false));
    }

    if (nextArrow instanceof HTMLButtonElement) {
      nextArrow.addEventListener('click', () => goRelative(1, false));
    }

    msHeroSlider.tabIndex = 0;
    msHeroSlider.addEventListener('keydown', (event) => {
      if (slides.length < 2) {
        return;
      }

      if (event.target instanceof HTMLElement && event.target.closest('[data-ms-dot-grid]')) {
        return;
      }

      if (event.key === 'ArrowRight') {
        goRelative(1, true);
        event.preventDefault();
      }

      if (event.key === 'ArrowLeft') {
        goRelative(-1, true);
        event.preventDefault();
      }
    });

    msHeroSlider.addEventListener('pointerenter', () => pauseAutoplay('pointer'));
    msHeroSlider.addEventListener('pointerleave', () => resumeAutoplay('pointer'));
    msHeroSlider.addEventListener('focusin', () => pauseAutoplay('focus'));
    msHeroSlider.addEventListener('focusout', (event) => {
      const nextTarget = event.relatedTarget;

      if (!(nextTarget instanceof Node) || !msHeroSlider.contains(nextTarget)) {
        resumeAutoplay('focus');
      }
    });

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        pauseAutoplay('visibility');
      } else {
        resumeAutoplay('visibility');
      }
    });

    syncSlideState(currentIndex);
    queueAutoplay();

    const parallaxScenes = Array.from(msHeroSlider.querySelectorAll('[data-ms-parallax-scene]'));

    parallaxScenes.forEach((scene) => {
      const updateFromPoint = (clientX, clientY) => {
        const rect = scene.getBoundingClientRect();
        const x = ((clientX - rect.left) / rect.width) - 0.5;
        const y = ((clientY - rect.top) / rect.height) - 0.5;

        scene.style.setProperty('--scene-shift-x', x.toFixed(3));
        scene.style.setProperty('--scene-shift-y', y.toFixed(3));
      };

      const reset = () => {
        scene.style.setProperty('--scene-shift-x', '0');
        scene.style.setProperty('--scene-shift-y', '0');
      };

      scene.addEventListener('pointermove', (event) => updateFromPoint(event.clientX, event.clientY));
      scene.addEventListener('pointerleave', reset);
      reset();
    });

    const dotScenes = Array.from(msHeroSlider.querySelectorAll('[data-ms-dot-scene]'));

    dotScenes.forEach((scene) => {
      const grid = scene.querySelector('[data-ms-dot-grid]');
      const dots = Array.from(scene.querySelectorAll('[data-ms-dot]'));

      if (!(grid instanceof HTMLElement) || dots.length === 0) {
        return;
      }

      const cols = Number(grid.dataset.dotCols || 28);
      const rows = Number(grid.dataset.dotRows || 14);
      let activeCol = Math.floor(cols / 2);
      let activeRow = Math.floor(rows / 2);

      const reset = () => {
        scene.style.setProperty('--reveal-strength', '0');
        scene.style.setProperty('--pointer-x', '50%');
        scene.style.setProperty('--pointer-y', '50%');

        dots.forEach((dot) => {
          dot.style.setProperty('--dot-scale', '1');
          dot.style.setProperty('--dot-color', 'rgba(9, 9, 11, 0.14)');
        });
      };

      const activate = (col, row) => {
        activeCol = Math.min(cols - 1, Math.max(0, col));
        activeRow = Math.min(rows - 1, Math.max(0, row));

        scene.style.setProperty('--reveal-strength', '1');
        scene.style.setProperty('--pointer-x', `${10 + ((activeCol / Math.max(cols - 1, 1)) * 80)}%`);
        scene.style.setProperty('--pointer-y', `${10 + ((activeRow / Math.max(rows - 1, 1)) * 80)}%`);

        dots.forEach((dot) => {
          const dotCol = Number(dot.dataset.col || 0);
          const dotRow = Number(dot.dataset.row || 0);
          const distance = Math.hypot(dotCol - activeCol, dotRow - activeRow);
          const scale = Math.max(1, 2.8 - (distance * 0.26));
          let color = `rgba(9, 9, 11, ${Math.max(0.08, 0.28 - (distance * 0.015)).toFixed(2)})`;

          if (distance < 1.2) {
            color = 'rgba(37, 99, 235, 0.92)';
          } else if (distance < 2.8) {
            color = 'rgba(17, 24, 38, 0.82)';
          }

          dot.style.setProperty('--dot-scale', scale.toFixed(2));
          dot.style.setProperty('--dot-color', color);
        });
      };

      const activateFromPoint = (clientX, clientY) => {
        const rect = grid.getBoundingClientRect();
        const x = (clientX - rect.left) / rect.width;
        const y = (clientY - rect.top) / rect.height;
        const col = Math.round(Math.min(1, Math.max(0, x)) * (cols - 1));
        const row = Math.round(Math.min(1, Math.max(0, y)) * (rows - 1));
        activate(col, row);
      };

      grid.addEventListener('pointerenter', (event) => activateFromPoint(event.clientX, event.clientY));
      grid.addEventListener('pointermove', (event) => activateFromPoint(event.clientX, event.clientY));
      grid.addEventListener('pointerdown', (event) => activateFromPoint(event.clientX, event.clientY));
      grid.addEventListener('pointerleave', reset);
      grid.addEventListener('focus', () => activate(activeCol, activeRow));
      grid.addEventListener('blur', reset);
      grid.addEventListener('keydown', (event) => {
        if (!['ArrowUp', 'ArrowDown', 'ArrowLeft', 'ArrowRight', 'Home', 'End'].includes(event.key)) {
          return;
        }

        event.preventDefault();

        if (event.key === 'ArrowUp') {
          activate(activeCol, activeRow - 1);
        }

        if (event.key === 'ArrowDown') {
          activate(activeCol, activeRow + 1);
        }

        if (event.key === 'ArrowLeft') {
          activate(activeCol - 1, activeRow);
        }

        if (event.key === 'ArrowRight') {
          activate(activeCol + 1, activeRow);
        }

        if (event.key === 'Home') {
          activate(0, 0);
        }

        if (event.key === 'End') {
          activate(cols - 1, rows - 1);
        }
      });

      reset();
    });
  });
</script>
