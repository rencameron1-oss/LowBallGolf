---
interface Props {
  slides: any[];
  autoplaySeconds?: number;
  ariaLabel?: string;
  sliderId?: string;
}

const {
  slides = [],
  autoplaySeconds = 7,
  ariaLabel = 'Creative hero slider',
  sliderId = `ms-hero-${Math.random().toString(36).slice(2, 10)}`,
} = Astro.props;

const dotGridRows = 14;
const dotGridCols = 28;
const dotGridCells = Array.from({ length: dotGridRows * dotGridCols }, (_, index) => ({
  index,
  row: Math.floor(index / dotGridCols),
  col: index % dotGridCols,
}));

const particleNodes = Array.from({ length: 28 }, (_, index) => ({
  index,
  top: `${6 + ((index * 17) % 82)}%`,
  left: `${4 + ((index * 29) % 90)}%`,
  size: `${0.18 + ((index % 5) * 0.07)}rem`,
  driftX: `${((index % 7) - 3) * 1.3}rem`,
  driftY: `${((index % 6) - 2.5) * 1.2}rem`,
  duration: `${10 + ((index * 3) % 9)}s`,
  delay: `${(index % 8) * -1.1}s`,
}));

const orbNodes = [
  { top: '8%', left: '8%', size: '22rem', color: 'rgba(37, 99, 235, 0.18)' },
  { top: '54%', left: '68%', size: '20rem', color: 'rgba(165, 90, 58, 0.16)' },
  { top: '18%', left: '56%', size: '16rem', color: 'rgba(142, 147, 100, 0.14)' },
];

const getPosterStyle = (poster: any, posterIndex: number) =>
  [
    `--poster-top:${poster.top || 'auto'}`,
    `--poster-left:${poster.left || 'auto'}`,
    `--poster-width:${poster.width || '18rem'}`,
    `--poster-rotate:${poster.rotate || '0deg'}`,
    `--poster-delay:${posterIndex * 90}ms`,
  ].join('; ');

const getParticleStyle = (particle: any) =>
  [
    `--particle-top:${particle.top}`,
    `--particle-left:${particle.left}`,
    `--particle-size:${particle.size}`,
    `--particle-drift-x:${particle.driftX}`,
    `--particle-drift-y:${particle.driftY}`,
    `--particle-duration:${particle.duration}`,
    `--particle-delay:${particle.delay}`,
  ].join('; ');

const isVideoAsset = (url: string) => {
  const normalizedUrl = url.toLowerCase();

  return (
    normalizedUrl.endsWith('.mp4') ||
    normalizedUrl.endsWith('.webm') ||
    normalizedUrl.endsWith('.ogg') ||
    normalizedUrl.endsWith('.ogv') ||
    normalizedUrl.endsWith('.mov')
  );
};

const getVideoType = (url: string) => {
  const normalizedUrl = url.toLowerCase();

  if (normalizedUrl.endsWith('.webm')) {
    return 'video/webm';
  }

  if (normalizedUrl.endsWith('.ogg') || normalizedUrl.endsWith('.ogv')) {
    return 'video/ogg';
  }

  if (normalizedUrl.endsWith('.mov')) {
    return 'video/quicktime';
  }

  return 'video/mp4';
};
---

{slides.length > 0 && (
  <section
    class="ms-home-hero"
    data-ms-hero-slider
    data-theme={slides[0]?.theme === 'light' ? 'light' : 'dark'}
    data-autoplay-seconds={String(autoplaySeconds)}
    data-slider-id={sliderId}
    aria-label={ariaLabel}
    aria-roledescription="carousel"
  >
    <div class="ms-home-hero__stage">
      {slides.map((slide, index) => {
        const revealImage = slide.image || slide.backgroundImage || '';
        const videoPoster = slide.videoPosterImage || slide.backgroundImage || slide.image || '';

        return (
          <section
            id={`${sliderId}-slide-${slide.id}`}
            class={`ms-home-slide ms-home-slide--${slide.layout} ${slide.theme === 'light' ? 'ms-home-slide--light' : 'ms-home-slide--dark'}`}
            data-ms-slide
            data-active={index === 0 ? 'true' : 'false'}
            data-theme={slide.theme === 'light' ? 'light' : 'dark'}
            data-layout={slide.layout}
            data-duration-seconds={String(slide.durationSeconds || autoplaySeconds || 0)}
            role="tabpanel"
            aria-hidden={index === 0 ? 'false' : 'true'}
          >
            {slide.layout === 'parallax' ? (
              <div class="ms-parallax-scene" data-ms-parallax-scene>
                <div class="ms-parallax-scene__backdrop" aria-hidden="true">
                  {slide.backgroundImage &&
                    (isVideoAsset(slide.backgroundImage) ? (
                      <video
                        autoplay
                        muted
                        loop
                        playsinline
                        preload={index === 0 ? 'auto' : 'metadata'}
                      >
                        <source src={slide.backgroundImage} type={getVideoType(slide.backgroundImage)} />
                      </video>
                    ) : (
                      <img src={slide.backgroundImage} alt="" loading={index === 0 ? 'eager' : 'lazy'} />
                    ))}
                </div>
                <div class="ms-parallax-scene__scrim"></div>

                {slide.image && (
                  <figure class="ms-parallax-scene__focus" aria-hidden="true">
                    {isVideoAsset(slide.image) ? (
                      <video
                        autoplay
                        muted
                        loop
                        playsinline
                        preload={index === 0 ? 'auto' : 'metadata'}
                      >
                        <source src={slide.image} type={getVideoType(slide.image)} />
                      </video>
                    ) : (
                      <img src={slide.image} alt="" loading={index === 0 ? 'eager' : 'lazy'} />
                    )}
                  </figure>
                )}

                {slide.posters.length > 0 && (
                  <div class="ms-parallax-scene__cluster" aria-hidden="true">
                    {slide.posters.map((poster, posterIndex) => (
                      <article
                        class={`ms-poster ms-poster--${poster.variant || 'landscape'} ms-poster--parallax`}
                        style={getPosterStyle(poster, posterIndex)}
                      >
                        {poster.kind === 'image' ? (
                          <>
                            <div class="ms-poster__media">
                              {poster.image && (
                                isVideoAsset(poster.image) ? (
                                  <video
                                    autoplay
                                    muted
                                    loop
                                    playsinline
                                    preload={index === 0 && posterIndex < 2 ? 'auto' : 'metadata'}
                                  >
                                    <source src={poster.image} type={getVideoType(poster.image)} />
                                  </video>
                                ) : (
                                  <img src={poster.image} alt="" loading={index === 0 && posterIndex < 2 ? 'eager' : 'lazy'} />
                                )
                              )}
                            </div>
                            <div class="ms-poster__body">
                              <span class="ms-poster__label">{poster.label}</span>
                              <h3 class="ms-poster__title">{poster.title}</h3>
                              <p class="ms-poster__meta">{poster.meta}</p>
                            </div>
                          </>
                        ) : (
                          <div class="ms-poster__body">
                            <span class="ms-poster__label">{poster.label}</span>
                            <h3 class="ms-poster__title">{poster.title}</h3>
                            <p class="ms-poster__meta">{poster.meta}</p>
                          </div>
                        )}
                      </article>
                    ))}
                  </div>
                )}
              </div>
            ) : slide.layout === 'video' ? (
              <div class="ms-video-scene">
                <div class="ms-video-scene__backdrop" aria-hidden="true">
                  {slide.videoUrl ? (
                    <video
                      autoplay
                      muted
                      loop
                      playsinline
                      preload={index === 0 ? 'auto' : 'metadata'}
                      poster={videoPoster}
                    >
                      <source src={slide.videoUrl} type={getVideoType(slide.videoUrl)} />
                    </video>
                  ) : (
                    slide.backgroundImage && (
                      <img src={slide.backgroundImage} alt="" loading={index === 0 ? 'eager' : 'lazy'} />
                    )
                  )}
                </div>
                <div class="ms-video-scene__scrim"></div>

                {slide.image && (
                  <figure class="ms-video-scene__feature" aria-hidden="true">
                    <img src={slide.image} alt="" loading={index === 0 ? 'eager' : 'lazy'} />
                  </figure>
                )}

                {slide.posters.length > 0 && (
                  <div class="ms-video-scene__rail" aria-hidden="true">
                    {slide.posters.slice(0, 3).map((poster, posterIndex) => (
                      <article
                        class={`ms-poster ms-poster--${poster.variant || 'landscape'} ms-poster--video`}
                        style={getPosterStyle(poster, posterIndex)}
                      >
                        {poster.kind === 'image' ? (
                          <>
                            <div class="ms-poster__media">
                              {poster.image && (
                                isVideoAsset(poster.image) ? (
                                  <video
                                    autoplay
                                    muted
                                    loop
                                    playsinline
                                    preload={index === 0 && posterIndex < 2 ? 'auto' : 'metadata'}
                                  >
                                    <source src={poster.image} type={getVideoType(poster.image)} />
                                  </video>
                                ) : (
                                  <img src={poster.image} alt="" loading={index === 0 && posterIndex < 2 ? 'eager' : 'lazy'} />
                                )
                              )}
                            </div>
                            <div class="ms-poster__body">
                              <span class="ms-poster__label">{poster.label}</span>
                              <h3 class="ms-poster__title">{poster.title}</h3>
                              <p class="ms-poster__meta">{poster.meta}</p>
                            </div>
                          </>
                        ) : (
                          <div class="ms-poster__body">
                            <span class="ms-poster__label">{poster.label}</span>
                            <h3 class="ms-poster__title">{poster.title}</h3>
                            <p class="ms-poster__meta">{poster.meta}</p>
                          </div>
                        )}
                      </article>
                    ))}
                  </div>
                )}
              </div>
            ) : slide.layout === 'mural' ? (
              <div class="ms-mural-scene">
                <div class="ms-mural-scene__backdrop" aria-hidden="true">
                  {slide.backgroundImage && (
                    <img src={slide.backgroundImage} alt="" loading={index === 0 ? 'eager' : 'lazy'} />
                  )}
                </div>
                <div class="ms-mural-scene__scrim"></div>

                {slide.posters.length > 0 && (
                  <div class="ms-mural-scene__cluster" aria-hidden="true">
                    {slide.posters.map((poster, posterIndex) => (
                      <article
                        class={`ms-poster ms-poster--${poster.variant || 'landscape'} ms-poster--mural`}
                        style={getPosterStyle(poster, posterIndex)}
                      >
                        {poster.kind === 'image' ? (
                          <>
                            <div class="ms-poster__media">
                              {poster.image && (
                                isVideoAsset(poster.image) ? (
                                  <video
                                    autoplay
                                    muted
                                    loop
                                    playsinline
                                    preload={index === 0 && posterIndex < 2 ? 'auto' : 'metadata'}
                                  >
                                    <source src={poster.image} type={getVideoType(poster.image)} />
                                  </video>
                                ) : (
                                  <img src={poster.image} alt="" loading={index === 0 && posterIndex < 2 ? 'eager' : 'lazy'} />
                                )
                              )}
                            </div>
                            <div class="ms-poster__body">
                              <span class="ms-poster__label">{poster.label}</span>
                              <h3 class="ms-poster__title">{poster.title}</h3>
                              <p class="ms-poster__meta">{poster.meta}</p>
                            </div>
                          </>
                        ) : (
                          <div class="ms-poster__body">
                            <span class="ms-poster__label">{poster.label}</span>
                            <h3 class="ms-poster__title">{poster.title}</h3>
                            <p class="ms-poster__meta">{poster.meta}</p>
                          </div>
                        )}
                      </article>
                    ))}
                  </div>
                )}
              </div>
            ) : slide.layout === 'poster' ? (
              <div class="ms-poster-scene">
                {slide.backgroundImage && (
                  <div class="ms-poster-scene__feature" aria-hidden="true">
                    <img src={slide.backgroundImage} alt="" loading={index === 0 ? 'eager' : 'lazy'} />
                  </div>
                )}
                <div class="ms-poster-scene__wash"></div>
                <div class="ms-poster-scene__graffiti" aria-hidden="true">
                  {slide.graffiti.map((tag) => (
                    <span style={`top:${tag.top || '50%'}; left:${tag.left || '50%'}; --graffiti-rotate:${tag.rotate || '0deg'};`}>
                      {tag.text}
                    </span>
                  ))}
                </div>
                <div class="ms-poster-scene__cluster" aria-hidden="true">
                  {slide.posters.map((poster, posterIndex) => (
                    <article
                      class={`ms-poster ms-poster--${poster.variant || 'landscape'}`}
                      style={getPosterStyle(poster, posterIndex)}
                    >
                      {poster.kind === 'image' ? (
                        <>
                          <div class="ms-poster__media">
                            {poster.image && (
                              isVideoAsset(poster.image) ? (
                                <video
                                  autoplay
                                  muted
                                  loop
                                  playsinline
                                  preload={index === 0 && posterIndex < 2 ? 'auto' : 'metadata'}
                                >
                                  <source src={poster.image} type={getVideoType(poster.image)} />
                                </video>
                              ) : (
                                <img src={poster.image} alt="" loading={index === 0 && posterIndex < 2 ? 'eager' : 'lazy'} />
                              )
                            )}
                          </div>
                          <div class="ms-poster__body">
                            <span class="ms-poster__label">{poster.label}</span>
                            <h3 class="ms-poster__title">{poster.title}</h3>
                            <p class="ms-poster__meta">{poster.meta}</p>
                          </div>
                        </>
                      ) : (
                        <div class="ms-poster__body">
                          <span class="ms-poster__label">{poster.label}</span>
                          <h3 class="ms-poster__title">{poster.title}</h3>
                          <p class="ms-poster__meta">{poster.meta}</p>
                        </div>
                      )}
                    </article>
                  ))}
                </div>
              </div>
            ) : (
              <div
                class="ms-dot-scene"
                data-ms-dot-scene
                style="--reveal-strength:0; --pointer-x:50%; --pointer-y:50%;"
              >
                <div class="ms-dot-scene__base" aria-hidden="true">
                  {slide.backgroundImage && (
                    <img src={slide.backgroundImage} alt="" loading={index === 0 ? 'eager' : 'lazy'} />
                  )}
                </div>
                <div class="ms-dot-scene__reveal" aria-hidden="true">
                  {revealImage && (
                    <img src={revealImage} alt="" loading={index === 0 ? 'eager' : 'lazy'} />
                  )}
                </div>
                <div class="ms-dot-scene__wash"></div>
                <div class="ms-dot-scene__grid-wrap">
                  <div
                    class="ms-dot-scene__grid"
                    data-ms-dot-grid
                    data-dot-cols={dotGridCols}
                    data-dot-rows={dotGridRows}
                    style={`--dot-cols:${dotGridCols}; --dot-rows:${dotGridRows};`}
                    tabindex="0"
                    role="group"
                    aria-label="Interactive dot field revealing the slide image"
                  >
                    <span class="ms-visually-hidden">
                      Hover, tap, or use the arrow keys to move through the dot field and reveal the image.
                    </span>
                    {dotGridCells.map((cell) => (
                      <span
                        class="ms-dot"
                        data-ms-dot
                        data-col={cell.col}
                        data-row={cell.row}
                        aria-hidden="true"
                      ></span>
                    ))}
                  </div>
                </div>
              </div>
            )}

            <div class="ms-slide-effects" aria-hidden="true">
              {slide.effects?.includes('grid') && <div class="ms-slide-effect ms-slide-effect--grid"></div>}
              {slide.effects?.includes('scanlines') && <div class="ms-slide-effect ms-slide-effect--scanlines"></div>}
              {slide.effects?.includes('mobile-glow') && <div class="ms-slide-effect ms-slide-effect--mobile-glow"></div>}
              {slide.effects?.includes('orbs') && (
                <div class="ms-slide-orbs">
                  {orbNodes.map((orb) => (
                    <span
                      style={`--orb-top:${orb.top}; --orb-left:${orb.left}; --orb-size:${orb.size}; --orb-color:${orb.color};`}
                    ></span>
                  ))}
                </div>
              )}
              {slide.effects?.includes('particles') && (
                <div class="ms-slide-particles">
                  {particleNodes.map((particle) => (
                    <span style={getParticleStyle(particle)}></span>
                  ))}
                </div>
              )}
            </div>
          </section>
        );
      })}

      <div class="ms-home-hero__veil"></div>

      <div class="ms-home-hero__overlay">
        <div class="ms-home-hero__overlay-inner">
          <div class="ms-home-hero__copy-stack">
            {slides.map((slide, index) => {
              return (
                <div
                  class={`ms-home-copy ${slide.theme === 'light' ? 'ms-home-copy--light' : ''} ${
                    slide.layout === 'dot-grid' ? 'ms-home-copy--wide' : ''
                  } ${slide.layout === 'video' ? 'ms-home-copy--video' : ''}`}
                  data-ms-copy
                  data-active={index === 0 ? 'true' : 'false'}
                  data-heading-font={slide.headingFont}
                  data-heading-size={slide.headingSize}
                >
                  <p class="ms-home-copy__eyebrow">{slide.eyebrow}</p>
                  <h1 class="ms-home-copy__title">{slide.heroHeading}</h1>
                  <p class="ms-home-copy__text">{slide.heroText}</p>
                  <div class="ms-home-copy__badges">
                    {slide.badges.map((badge) => (
                      <span>{badge}</span>
                    ))}
                  </div>
                  {(slide.primaryCtaText || slide.secondaryCtaText) && (
                    <div class="ms-home-copy__actions">
                      {slide.primaryCtaText && slide.primaryCtaUrl && (
                        <a
                          class={`ms-home-copy__button ${slide.theme === 'light' ? 'ms-home-copy__button--dark' : 'ms-home-copy__button--primary'}`}
                          href={slide.primaryCtaUrl}
                        >
                          {slide.primaryCtaText}
                        </a>
                      )}
                      {slide.secondaryCtaText && slide.secondaryCtaUrl && (
                        <a
                          class={`ms-home-copy__button ${slide.theme === 'light' ? 'ms-home-copy__button--ghost-dark' : 'ms-home-copy__button--ghost'}`}
                          href={slide.secondaryCtaUrl}
                        >
                          {slide.secondaryCtaText}
                        </a>
                      )}
                    </div>
                  )}
                </div>
              );
            })}
          </div>

          {slides.length > 1 && (
            <div class="ms-home-hero__controls" aria-label={`${ariaLabel} controls`}>
              <button
                type="button"
                class="ms-home-hero__arrow"
                data-ms-arrow-prev
                aria-label="Show previous slide"
                disabled
              >
                <svg viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                  <path d="M9.75 3.5 5.25 8l4.5 4.5" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6"></path>
                </svg>
              </button>

              <div class="ms-home-hero__nav" role="tablist" aria-label={`${ariaLabel} views`}>
                {slides.map((slide, index) => (
                  <button
                    type="button"
                    class="ms-home-hero__nav-button"
                    data-ms-control
                    data-index={index}
                    data-active={index === 0 ? 'true' : 'false'}
                    role="tab"
                    tabindex={index === 0 ? '0' : '-1'}
                    aria-selected={index === 0 ? 'true' : 'false'}
                    aria-controls={`${sliderId}-slide-${slide.id}`}
                    aria-label={`Show slide ${index + 1}: ${slide.tab}`}
                  >
                    <span class="ms-home-hero__nav-dot" aria-hidden="true"></span>
                    <span class="ms-visually-hidden">{slide.tab}</span>
                  </button>
                ))}
              </div>

              <button
                type="button"
                class="ms-home-hero__arrow"
                data-ms-arrow-next
                aria-label="Show next slide"
              >
                <svg viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                  <path d="m6.25 3.5 4.5 4.5-4.5 4.5" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6"></path>
                </svg>
              </button>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
)}

<style>
  .ms-home-hero {
    --ms-header-offset: 4.5rem;
    position: relative;
    width: 100vw;
    margin-right: calc(50% - 50vw);
    margin-left: calc(50% - 50vw);
    margin-top: calc(-1 * var(--ms-header-offset));
  }

  .ms-home-hero__stage {
    position: relative;
    min-height: 100svh;
    overflow: hidden;
    background: #090b10;
  }

  .ms-home-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 620ms ease,
      transform 620ms ease,
      filter 620ms ease;
    transform: scale(1.02);
    filter: blur(8px);
  }

  .ms-home-slide[data-active='true'] {
    opacity: 1;
    pointer-events: auto;
    transform: none;
    filter: none;
  }

  .ms-home-slide--dark {
    color: #f2efe8;
  }

  .ms-home-slide--light {
    color: #09090b;
  }

  .ms-home-hero__veil {
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      linear-gradient(90deg, rgba(6, 8, 11, 0.92) 0%, rgba(6, 8, 11, 0.8) 18%, rgba(6, 8, 11, 0.42) 36%, rgba(6, 8, 11, 0.12) 58%, rgba(6, 8, 11, 0.34) 78%, rgba(6, 8, 11, 0.62) 100%),
      linear-gradient(180deg, rgba(6, 8, 11, 0.22) 0%, rgba(6, 8, 11, 0.02) 26%, rgba(6, 8, 11, 0.38) 100%);
    pointer-events: none;
  }

  .ms-home-hero[data-theme='light'] .ms-home-hero__veil {
    background:
      linear-gradient(90deg, rgba(250, 250, 247, 0.74) 0%, rgba(250, 250, 247, 0.38) 32%, rgba(250, 250, 247, 0.08) 64%, rgba(250, 250, 247, 0.26) 100%),
      linear-gradient(180deg, rgba(250, 250, 247, 0.18) 0%, rgba(250, 250, 247, 0) 28%, rgba(250, 250, 247, 0.24) 100%);
  }

  .ms-home-hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 3;
    padding:
      calc(var(--ms-header-offset) + 1.5rem)
      clamp(1rem, 4vw, 3.75rem)
      1.8rem;
    pointer-events: none;
  }

  .ms-home-hero__overlay-inner {
    display: flex;
    min-height: calc(100svh - (var(--ms-header-offset) + 3.6rem));
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-end;
  }

  .ms-home-hero__copy-stack {
    position: relative;
    width: min(38rem, 42vw);
    min-height: 22rem;
    margin-bottom: 6rem;
    pointer-events: auto;
  }

  .ms-home-copy {
    --hero-heading-font: var(--font-hero-heading, var(--font-heading));
    --hero-heading-size: clamp(2.8rem, 5.2vw, 5.2rem);
    --hero-heading-line-height: 1;
    --hero-heading-weight: 800;
    position: absolute;
    inset: auto 0 0;
    width: 100%;
    opacity: 0;
    transform: translateY(1rem);
    transition:
      opacity 420ms ease,
      transform 420ms ease;
    color: #f2efe8;
  }

  .ms-home-copy[data-active='true'] {
    opacity: 1;
    transform: none;
  }

  .ms-home-copy--light {
    color: #09090b;
  }

  .ms-home-copy--wide {
    width: min(46rem, 50vw);
  }

  .ms-home-copy--video {
    width: min(36rem, 38vw);
  }

  .ms-home-copy[data-heading-font='heading'] {
    --hero-heading-font: var(--font-heading);
  }

  .ms-home-copy[data-heading-font='body'] {
    --hero-heading-font: var(--font-body);
    --hero-heading-weight: 800;
  }

  .ms-home-copy[data-heading-font='logo'] {
    --hero-heading-font: var(--font-logo);
  }

  .ms-home-copy[data-heading-size='compact'] {
