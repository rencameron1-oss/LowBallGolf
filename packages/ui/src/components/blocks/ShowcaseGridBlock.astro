---
import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';

interface ShowcaseStat {
  value?: string;
  label?: string;
}

interface ShowcaseItem {
  url?: string;
  image?: string;
  eyebrow?: string;
  title?: string;
  summary?: string;
  chips?: string[];
  stats?: (string | ShowcaseStat)[];
}

function normalizeStat(stat: string | ShowcaseStat): ShowcaseStat {
  if (typeof stat === 'string') {
    const [left, ...rest] = stat.split(':');
    const right = rest.join(':').trim();
    if (right) return { value: left.trim(), label: right };
    return { value: '', label: left.trim() };
  }
  return stat;
}

interface Props {
  kicker?: string;
  heading?: string;
  subheading?: string;
  items?: ShowcaseItem[];
  columns?: number | string;
  image_fit?: string;
  image_aspect?: string;
}

const {
  kicker,
  heading,
  subheading,
  items = [],
  columns = 3,
  image_fit = 'cover',
  image_aspect = '16/10',
} = Astro.props;

const normalizedColumns = Number(columns) || 3;
const colClasses: Record<number, string> = {
  2: 'grid-cols-1 md:grid-cols-2',
  3: 'grid-cols-1 md:grid-cols-2 xl:grid-cols-3',
  4: 'grid-cols-1 md:grid-cols-2 xl:grid-cols-4',
};

const aspectClasses: Record<string, string> = {
  '16/10': 'aspect-[16/10]',
  '4/3': 'aspect-[4/3]',
  '1/1': 'aspect-square',
  '3/2': 'aspect-[3/2]',
};
const aspectClass = aspectClasses[image_aspect] || aspectClasses['16/10'];

const isContain = image_fit === 'contain';
const imageWrapClass = isContain
  ? `${aspectClass} overflow-hidden bg-white flex items-center justify-center p-8`
  : `${aspectClass} overflow-hidden bg-brand-surface-alt`;
const imageClass = isContain
  ? 'h-full w-full object-contain'
  : 'h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]';
---

{items.length > 0 && (
  <section class="py-20 md:py-28">
    <Container width="wide">
      {(heading || subheading || kicker) && (
        <div class="reveal">
          <SectionHeading kicker={kicker} heading={heading || ''} subheading={subheading} />
        </div>
      )}

      <div class:list={['grid gap-6 md:gap-8', colClasses[normalizedColumns] || colClasses[3]]}>
        {items.map((item, index) => {
          const cardClasses =
            'group overflow-hidden rounded-[1.8rem] border border-brand-border/40 bg-brand-surface/90 shadow-[0_24px_60px_rgba(15,23,42,0.08)] transition-all duration-300 hover:-translate-y-1 hover:border-brand-accent/30 hover:shadow-[0_28px_70px_rgba(15,23,42,0.14)]';

          const cardBody = (
            <>
              {item.image && (
                <div class={imageWrapClass}>
                  <img
                    src={item.image}
                    alt={item.title || item.eyebrow || 'Showcase image'}
                    class={imageClass}
                    loading="lazy"
                  />
                </div>
              )}
              <div class="flex flex-col gap-4 p-6">
                {item.eyebrow && (
                  <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-accent/80">
                    {item.eyebrow}
                  </p>
                )}
                {item.title && (
                  <h3 class="text-2xl font-heading font-semibold tracking-tight text-brand-text">
                    {item.title}
                  </h3>
                )}
                {item.summary && (
                  <p class="text-base leading-relaxed text-brand-muted">
                    {item.summary}
                  </p>
                )}
                {item.chips && item.chips.length > 0 && (
                  <div class="flex flex-wrap gap-2">
                    {item.chips.map((chip) => (
                      <span class="rounded-full border border-brand-border/50 bg-white/60 px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-brand-muted">
                        {chip.trim()}
                      </span>
                    ))}
                  </div>
                )}
                {item.stats && item.stats.length > 0 && (
                  <div class="mt-2 grid grid-cols-2 gap-3 sm:grid-cols-3">
                    {item.stats.map((rawStat) => {
                      const stat = normalizeStat(rawStat);
                      return (
                        <div class="rounded-2xl border border-brand-border/50 bg-brand-surface-alt/60 p-4">
                          {stat.value && (
                            <p class="font-heading text-3xl font-semibold leading-tight text-brand-accent">
                              {stat.value}
                            </p>
                          )}
                          {stat.label && (
                            <p class="mt-2 text-sm font-medium leading-snug text-brand-text">
                              {stat.label}
                            </p>
                          )}
                        </div>
                      );
                    })}
                  </div>
                )}
              </div>
            </>
          );

          return item.url ? (
            <a
              href={item.url}
              class:list={[cardClasses, `reveal reveal-delay-${Math.min((index % 4) + 1, 4)}`]}
            >
              {cardBody}
            </a>
          ) : (
            <article class:list={[cardClasses, `reveal reveal-delay-${Math.min((index % 4) + 1, 4)}`]}>
              {cardBody}
            </article>
          );
        })}
      </div>
    </Container>
  </section>
)}
