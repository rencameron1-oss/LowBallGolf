---
interface Props {
  quote: string;
  author_name: string;
  author_role?: string;
  author_image?: string;
  rating?: number;
  background?: 'default' | 'surface' | 'accent';
}

const {
  quote,
  author_name,
  author_role,
  author_image,
  rating,
  background = 'surface',
} = Astro.props;

const bgClasses: Record<string, string> = {
  default: '',
  surface: 'bg-brand-surface',
  accent: 'bg-gradient-to-br from-brand-accent/10 via-brand-surface to-brand-surface-alt',
};

const stars = rating ? Array.from({ length: 5 }, (_, i) => i < rating) : [];
---

<section class:list={['py-20 md:py-28', bgClasses[background]]}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
    <!-- Quote mark -->
    <div class="mb-8">
      <svg class="w-12 h-12 mx-auto text-brand-accent/40" fill="currentColor" viewBox="0 0 24 24">
        <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609L9.978 5.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H0z"/>
      </svg>
    </div>

    {stars.length > 0 && (
      <div class="flex items-center justify-center gap-1 mb-6">
        {stars.map((filled) => (
          <svg
            class:list={['w-5 h-5', filled ? 'text-brand-accent' : 'text-brand-border']}
            fill="currentColor"
            viewBox="0 0 20 20"
          >
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
        ))}
      </div>
    )}

    <blockquote class="text-2xl md:text-3xl lg:text-4xl font-heading font-medium text-brand-champagne leading-relaxed italic">
      &ldquo;{quote}&rdquo;
    </blockquote>

    <div class="mt-10 flex items-center justify-center gap-4">
      {author_image && (
        <img
          src={author_image}
          alt={author_name}
          class="w-14 h-14 rounded-full object-cover border-2 border-brand-accent/30"
          loading="lazy"
        />
      )}
      <div class:list={[author_image ? 'text-left' : 'text-center']}>
        <cite class="not-italic font-semibold text-brand-champagne text-lg">{author_name}</cite>
        {author_role && (
          <p class="text-brand-accent text-sm mt-0.5">{author_role}</p>
        )}
      </div>
    </div>
  </div>
</section>
