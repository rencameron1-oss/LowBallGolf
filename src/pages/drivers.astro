---
import PageLayout from '../layouts/PageLayout.astro';
import { fetchClubs, dollars } from '../utils/priceData';

// Card grid of every tracked driver with client-side filtering. Data is
// fetched at build time; the page is static and refreshed by the nightly
// scrape + rebuild.
const clubs = await fetchClubs();

const cards = clubs
  .map((c) => {
    const best = c.offers[0];
    const worst = c.offers[c.offers.length - 1];
    return {
      slug: c.slug,
      brand: c.brand,
      model: c.model,
      image: c.image,
      isLadies: c.isLadies,
      hands: c.hands,
      bestPrice: best.price,
      bestStore: best.name,
      saving: worst.price - best.price,
      stores: c.offers.length,
    };
  })
  .sort((a, b) => b.saving - a.saving || a.bestPrice - b.bestPrice);

const brands = [...new Set(cards.map((c) => c.brand))]
  .sort()
  .map((b) => ({ name: b, count: cards.filter((c) => c.brand === b).length }));

const updatedAt = new Date().toLocaleDateString('en-AU', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
  timeZone: 'Australia/Melbourne',
});
---

<PageLayout
  title="Compare Driver Prices"
  description="Compare golf driver prices across major Australian retailers. Filter by brand, gender and hand, and find the cheapest store for every model."
>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400..700&family=Inter:wght@400..700&display=swap"
    rel="stylesheet"
  />

  <div class="dp">
    <div class="dp-wrap">
      <header class="dp-head">
        <p class="dp-kicker">Updated nightly · last check {updatedAt}</p>
        <h1 class="dp-title">Drivers</h1>
        <p class="dp-sub">
          Every driver we track across Australian golf retailers, biggest saving first.
        </p>
      </header>

      {cards.length === 0 ? (
        <p class="dp-empty">Price data is being updated right now — check back shortly.</p>
      ) : (
        <div class="dp-layout">
          <aside class="dp-filters" aria-label="Filters">
            <div class="dp-filter-head">
              <span>Filters</span>
              <button type="button" id="dpClear" hidden>Clear all</button>
            </div>

            <fieldset class="dp-group">
              <legend>Brand</legend>
              {brands.map((b) => (
                <label class="dp-check">
                  <input type="checkbox" name="brand" value={b.name} />
                  <span>{b.name}</span>
                  <em>{b.count}</em>
                </label>
              ))}
            </fieldset>

            <fieldset class="dp-group">
              <legend>Gender</legend>
              <label class="dp-check"><input type="radio" name="gender" value="all" checked /><span>All</span></label>
              <label class="dp-check"><input type="radio" name="gender" value="mens" /><span>Men's</span></label>
              <label class="dp-check"><input type="radio" name="gender" value="ladies" /><span>Ladies</span></label>
            </fieldset>

            <fieldset class="dp-group">
              <legend>Hand</legend>
              <label class="dp-check"><input type="radio" name="hand" value="all" checked /><span>All</span></label>
              <label class="dp-check"><input type="radio" name="hand" value="right" /><span>Right hand</span></label>
              <label class="dp-check"><input type="radio" name="hand" value="left" /><span>Left hand</span></label>
            </fieldset>
          </aside>

          <main class="dp-main">
            <div class="dp-toolbar">
              <p class="dp-count" id="dpCount">{cards.length} drivers</p>
              <label class="dp-sort">
                <span>Sort</span>
                <select id="dpSort">
                  <option value="saving" selected>Biggest saving</option>
                  <option value="price-asc">Price: low to high</option>
                  <option value="price-desc">Price: high to low</option>
                  <option value="brand">Brand A–Z</option>
                </select>
              </label>
            </div>
            <div class="dp-grid" id="dpGrid">
              {cards.map((c) => (
                <a
                  class="dp-card"
                  href={`/clubs/${c.slug}`}
                  data-brand={c.brand}
                  data-gender={c.isLadies ? 'ladies' : 'mens'}
                  data-hands={c.hands.join(' ')}
                  data-price={String(c.bestPrice)}
                  data-saving={String(c.saving)}
                  data-model={c.model}
                >
                  {c.saving > 0 && <span class="dp-save">Save {dollars(c.saving)}</span>}
                  <span class="dp-img">
                    {c.image ? (
                      <img src={c.image} alt={`${c.brand} ${c.model}`} loading="lazy" />
                    ) : (
                      <svg viewBox="0 0 64 64" aria-hidden="true">
                        <circle cx="32" cy="32" r="30" fill="#eef1ec"></circle>
                        <path d="M 12 46 A 30 30 0 0 0 52 46 A 40 40 0 0 1 12 46 Z" fill="#dde4da" opacity=".7"></path>
                      </svg>
                    )}
                  </span>
                  <span class="dp-brand">{c.brand}</span>
                  <span class="dp-name">{c.model}{c.isLadies ? ' — Ladies' : ''}</span>
                  <span class="dp-price">
                    <strong>{dollars(c.bestPrice)}</strong>
                    <em>at {c.bestStore}{c.stores > 1 ? ` · ${c.stores} stores` : ''}</em>
                  </span>
                </a>
              ))}
            </div>
            <p class="dp-none" id="dpNone" hidden>No drivers match those filters.</p>
            <p class="dp-note">
              Prices are collected nightly from retailer websites and can change at any time.
              Always confirm the price on the retailer's site before buying.
            </p>
          </main>
        </div>
      )}
    </div>
  </div>
</PageLayout>

<style>
  .dp {
    --serif: 'Fraunces', Georgia, serif;
    --sans: 'Inter', system-ui, sans-serif;
    background:
      linear-gradient(rgba(6, 23, 15, 0.9), rgba(6, 23, 15, 0.94)),
      url('/images/club-bg.jpg') center / cover no-repeat #071a11;
    color: #f2f4ef;
    font-family: var(--sans);
    padding: 40px 0 90px;
  }

  @media (min-width: 768px) {
    .dp {
      background-attachment: fixed;
    }
  }

  .dp-wrap {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .dp-head {
    margin-bottom: 34px;
  }

  .dp-kicker {
    margin: 0 0 10px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(201, 212, 201, 0.85);
  }

  .dp-title {
    margin: 0;
    font-family: var(--serif);
    font-optical-sizing: auto;
    font-weight: 560;
    font-size: clamp(38px, 5vw, 58px);
    line-height: 1;
    color: #f7f8f4;
  }

  .dp-sub {
    margin: 12px 0 0;
    font-size: 15px;
    color: #c9d4c9;
  }

  .dp-empty,
  .dp-none {
    padding: 40px 0;
    text-align: center;
    color: #c9d4c9;
  }

  .dp-layout {
    display: grid;
    grid-template-columns: 230px minmax(0, 1fr);
    gap: 30px;
    align-items: start;
  }

  @media (max-width: 900px) {
    .dp-layout {
      grid-template-columns: 1fr;
    }
  }

  /* ---------- filter rail ---------- */
  .dp-filters {
    position: sticky;
    top: 96px;
    border: 1px solid rgba(201, 212, 201, 0.24);
    border-radius: 8px;
    background: rgba(6, 23, 15, 0.72);
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
    padding: 18px 18px 8px;
  }

  @media (max-width: 900px) {
    .dp-filters {
      position: static;
    }
  }

  .dp-filter-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(201, 212, 201, 0.85);
  }

  .dp-filter-head button {
    background: none;
    border: 0;
    padding: 0;
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: none;
    color: #f5c944;
    cursor: pointer;
  }

  .dp-group {
    border: 0;
    margin: 0 0 6px;
    padding: 12px 0;
    border-top: 1px solid rgba(201, 212, 201, 0.14);
  }

  .dp-group legend {
    padding: 0 0 8px;
    font-size: 12px;
    font-weight: 650;
    color: #f2f4ef;
  }

  .dp-check {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 5px 0;
    font-size: 13px;
    color: #c9d4c9;
    cursor: pointer;
  }

  .dp-check:hover {
    color: #f5c944;
  }

  .dp-check input {
    accent-color: #f5c944;
    width: 15px;
    height: 15px;
    cursor: pointer;
  }

  .dp-check em {
    margin-left: auto;
    font-style: normal;
    font-size: 11px;
    color: rgba(201, 212, 201, 0.55);
  }

  /* ---------- cards ---------- */
  .dp-toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 14px;
    margin-bottom: 14px;
  }

  .dp-count {
    margin: 0;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: rgba(201, 212, 201, 0.8);
  }

  .dp-sort {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: rgba(201, 212, 201, 0.8);
  }

  .dp-sort select {
    appearance: none;
    padding: 7px 30px 7px 12px;
    background:
      url("data:image/svg+xml;charset=utf-8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23c9d4c9' stroke-width='2.4'%3E%3Cpath d='M6 9l6 6 6-6'/%3E%3C/svg%3E")
      right 10px center / 12px no-repeat,
      rgba(6, 23, 15, 0.72);
    border: 1px solid rgba(201, 212, 201, 0.3);
    border-radius: 6px;
    color: #f2f4ef;
    font-family: var(--sans);
    font-size: 12.5px;
    font-weight: 500;
    cursor: pointer;
  }

  .dp-sort select:hover,
  .dp-sort select:focus {
    border-color: #f5c944;
    outline: none;
  }

  .dp-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  @media (max-width: 1080px) {
    .dp-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .dp-grid {
      /* minmax(0, …) stops oversized product images from blowing the
         track (and the whole page) out sideways on iOS Safari. */
      grid-template-columns: minmax(0, 1fr);
    }
  }

  .dp-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: #ffffff;
    border-radius: 10px;
    padding: 16px 16px 18px;
    text-decoration: none;
    color: #17241d;
    box-shadow: 0 8px 22px rgba(0, 0, 0, 0.25);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .dp-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 34px rgba(0, 0, 0, 0.35);
  }

  .dp-card[hidden] {
    display: none;
  }

  .dp-save {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 1;
    padding: 5px 9px;
    background: #f5c944;
    color: #0d3527;
    font-size: 11px;
    font-weight: 650;
    border-radius: 4px;
    transform: rotate(-2deg);
    box-shadow: 0 3px 8px rgba(0, 0, 0, 0.18);
  }

  .dp-img {
    display: grid;
    place-items: center;
    /* Fixed height (not aspect-ratio) so Safari resolves the image's
       max-height against a definite box. */
    height: 210px;
    min-width: 0;
    margin-bottom: 12px;
  }

  .dp-img img,
  .dp-img svg {
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .dp-img svg {
    width: 55%;
  }

  .dp-brand {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: #8a978d;
  }

  .dp-name {
    margin-top: 3px;
    font-size: 15px;
    font-weight: 650;
    line-height: 1.35;
    color: #17241d;
  }

  .dp-price {
    margin-top: 10px;
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-wrap: wrap;
  }

  .dp-price strong {
    font-family: var(--serif);
    font-optical-sizing: auto;
    font-weight: 600;
    font-size: 21px;
    color: #0d3527;
  }

  .dp-price em {
    font-style: normal;
    font-size: 11.5px;
    color: #8a978d;
  }

  .dp-note {
    margin: 26px 0 0;
    font-size: 12px;
    line-height: 1.7;
    color: rgba(201, 212, 201, 0.6);
  }
</style>

<script>
  const grid = document.getElementById('dpGrid');
  const countEl = document.getElementById('dpCount');
  const noneEl = document.getElementById('dpNone');
  const clearBtn = document.getElementById('dpClear');

  if (grid && countEl && noneEl && clearBtn) {
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.dp-card'));
    const brandBoxes = Array.from(
      document.querySelectorAll<HTMLInputElement>('input[name="brand"]')
    );
    const radios = (name: string) =>
      document.querySelector<HTMLInputElement>(`input[name="${name}"]:checked`)?.value ?? 'all';

    const apply = () => {
      const activeBrands = brandBoxes.filter((b) => b.checked).map((b) => b.value);
      const gender = radios('gender');
      const hand = radios('hand');

      let shown = 0;
      for (const card of cards) {
        const okBrand = activeBrands.length === 0 || activeBrands.includes(card.dataset.brand || '');
        const okGender = gender === 'all' || card.dataset.gender === gender;
        const okHand = hand === 'all' || (card.dataset.hands || '').split(' ').includes(hand);
        const ok = okBrand && okGender && okHand;
        card.hidden = !ok;
        if (ok) shown++;
      }
      countEl.textContent = `${shown} driver${shown === 1 ? '' : 's'}`;
      noneEl.hidden = shown > 0;
      clearBtn.hidden = activeBrands.length === 0 && gender === 'all' && hand === 'all';
    };

    document
      .querySelectorAll<HTMLInputElement>('.dp-filters input')
      .forEach((i) => i.addEventListener('change', apply));

    clearBtn.addEventListener('click', () => {
      brandBoxes.forEach((b) => (b.checked = false));
      document
        .querySelectorAll<HTMLInputElement>('input[value="all"]')
        .forEach((r) => (r.checked = true));
      apply();
    });

    // Sorting reorders the card elements in place; filters are untouched.
    const sortSel = document.getElementById('dpSort') as HTMLSelectElement | null;
    sortSel?.addEventListener('change', () => {
      const num = (c: HTMLElement, k: string) => parseFloat(c.dataset[k] || '0');
      const byBrand = (a: HTMLElement, b: HTMLElement) =>
        (a.dataset.brand || '').localeCompare(b.dataset.brand || '') ||
        (a.dataset.model || '').localeCompare(b.dataset.model || '');
      const cmp: Record<string, (a: HTMLElement, b: HTMLElement) => number> = {
        saving: (a, b) => num(b, 'saving') - num(a, 'saving') || num(a, 'price') - num(b, 'price'),
        'price-asc': (a, b) => num(a, 'price') - num(b, 'price'),
        'price-desc': (a, b) => num(b, 'price') - num(a, 'price'),
        brand: byBrand,
      };
      const sorted = [...cards].sort(cmp[sortSel.value] ?? cmp.saving);
      sorted.forEach((c) => grid.appendChild(c));
    });
  }
</script>
